{
  "name": "@rtas/design-tokens",
  "version": "1.0.0",
  "private": true,
  "description": "RTAS Studio AI design system — tokens, motion, and Tailwind preset",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./css/tokens.css": "./css/tokens.css",
    "./css/motion.css": "./css/motion.css",
    "./tailwind": {
      "types": "./tailwind/preset.d.ts",
      "default": "./tailwind/preset.js"
    }
  },
  "sideEffects": [
    "./css/tokens.css",
    "./css/motion.css"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@rtas/config": "*",
    "typescript": "^5.4.0"
  }
}
