# CORS (Next.js frontend) — include production origin when live
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example:
# CORS_ORIGINS=https://REPLACE_APP_DOMAIN,https://www.REPLACE_APP_DOMAIN

PUBLIC_BASE_URL=http://localhost:8000
# Production example:
# PUBLIC_BASE_URL=https://api.REPLACE_APP_DOMAIN

# AI routing: simulation | replicate | comfyui | diffusers | auto
AI_PROVIDER_MODE=auto

# Replicate (https://replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=
REPLICATE_MODEL_I2V=wavespeedai/wan-2.1-i2v-480p
REPLICATE_MODEL_T2V=wavespeedai/wan-2.1-t2v-480p
REPLICATE_MODEL_REAL_FACE=wavespeedai/wan-2.1-i2v-480p
REPLICATE_POLL_INTERVAL_SEC=2
REPLICATE_POLL_TIMEOUT_SEC=600
REPLICATE_CACHE_OUTPUTS_LOCALLY=true

# Shared secret for internal worker callbacks (must match web RTAS_GENERATION_WEBHOOK_SECRET)
AI_BACKEND_SECRET=

# ComfyUI remote / RunPod instance
COMFYUI_API_URL=
COMFYUI_API_KEY=

# Cloud APIs
FAL_API_KEY=
# Alias used by some deploy docs — prefer FAL_API_KEY or sync from web FAL_KEY
# FAL_KEY=
RUNWAY_API_KEY=
KLING_API_KEY=

# Local GPU worker — Diffusers + InstantID
DIFFUSERS_ENABLED=false
DIFFUSERS_DEVICE=cuda
INSTANTID_MODEL_PATH=

# Storage
STORAGE_MODE=local
LOCAL_UPLOAD_DIR=data/uploads
LOCAL_OUTPUT_DIR=data/outputs
MAX_UPLOAD_BYTES=52428800

# S3 / Cloudflare R2 (production object storage)
# S3_BUCKET=REPLACE_MEDIA_BUCKET
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://assets.REPLACE_APP_DOMAIN
