  referredUserId        String?
  status                String   @default("invited")
  rewardCredits         Int      @default(0)
  referredBonusCredits  Int      @default(0)
  invitedAt             DateTime @default(now())
  signedUpAt            DateTime?
  convertedAt           DateTime?
  rewardedAt            DateTime?
  metadataJson          Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([referrerUserId])
  @@index([referredUserId])
  @@index([status])
  @@map("Referrals")
}

model Affiliate {
  id                 String   @id @default(uuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId             String
  name               String   @default("")
  email              String   @default("")
  status             String   @default("active")
  commissionType     String   @default("percentage")
  commissionRate     Float    @default(20)
  recurringRatePct   Float    @default(10)
  payoutMethod       String   @default("paypal")
  parentAffiliateId  String?
  pendingUsd         Float    @default(0)
  approvedUsd        Float    @default(0)
  paidUsd            Float    @default(0)
  lifetimeUsd        Float    @default(0)
  metadataJson       Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  campaigns          AffiliateCampaign[]
  clicks             AffiliateClick[]
  conversions        AffiliateConversion[]
  commissionEntries  Commission[]
  payoutRequests     PayoutRequest[]
  payoutHistory      PayoutHistory[]

  @@unique([organizationId, userId])
  @@index([status])
  @@index([parentAffiliateId])
  @@map("Affiliates")
}

model AffiliateCampaign {
  id               String   @id @default(uuid())
  affiliateId      String
  affiliate        Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
