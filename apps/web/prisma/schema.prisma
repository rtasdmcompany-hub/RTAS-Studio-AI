  versionId      String?
  createdAt      DateTime @default(now())

  @@index([organizationId, projectId, createdAt(sort: Desc)])
  @@index([changeType])
  @@index([actorId])
}

model OrgProjectRollbackHistory {
  id             String   @id @default(uuid())
  organizationId String
