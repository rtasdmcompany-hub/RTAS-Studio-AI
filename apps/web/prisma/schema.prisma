datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  image         String?
  provider      String   @default("credentials")
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Studio profile & SaaS generation limits
  tier                   String    @default("free")
  credits                Int       @default(50)
  concurrentTracks       Int       @default(0)
  creditsExpireAt        DateTime?
  subscriptionActive     Boolean   @default(false)
  subscriptionRenewsAt   DateTime?
  freeTrialUsed          Boolean   @default(false)
  hasUsedFreeTrial       Boolean   @default(false)
  previewSkipsRemaining  Int       @default(3)
  paymentProvider        String?
  externalCustomerId     String?
  externalSubscriptionId String?

  generationJobs GenerationJob[]
  projects       Project[]
  audioJobs      AudioJob[]
  voiceJobs      VoiceJob[]
  voiceClones    VoiceClone[]
  characterVoices CharacterVoice[]
  speakerProfiles SpeakerProfile[]
  musicJobs      MusicJob[]
  sfxJobs        SfxJob[]
}

/** Durable studio project — every generation creates/updates one. */
model Project {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  prompt          String?
  inputImageUrl   String?
  audioUrl        String?
  settings        Json?
  durationSeconds Int      @default(0)
  creditsUsed     Int      @default(0)
  provider        String?
  outputUrl       String?
  status          String   @default("queued")
  latestJobId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  generationJobs GenerationJob[]
  audioJobs      AudioJob[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
}

model GenerationJob {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId         String?
  project           Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status            GenerationJobStatus @default(QUEUED)
  prompt            String?
  inputImageUrl     String?
  audioUrl          String?
  generatedVideoUrl String?
  durationSeconds   Int                 @default(0)
  creditsCharged    Int                 @default(0)
  creditsDebited    Boolean             @default(false)
  provider          String?
  settings          Json?
  progressPercent   Int                 @default(0)
  stageLabel        String?
  queuePosition     Int?
  estimatedSecondsRemaining Int?
  retryCount        Int                 @default(0)
  chunkTotal        Int?
  chunksCompleted   Int?
  chunkManifest     Json?
  errorMessage      String?
  backendJobId      String?
  isPublic          Boolean             @default(false)
  shareTitle        String?
  publishedAt       DateTime?
  startedAt         DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  completedAt       DateTime?

  audioJobs         AudioJob[]

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([projectId])
  @@index([isPublic])
}

enum GenerationJobStatus {
  QUEUED
  PREPARING
  GENERATING
  GENERATING_CHUNKS
  RENDERING
  COMPILING_MEDIA
  UPLOADING
  COMPLETED
  FAILED
  CANCELLED
}

/** Phase 4 — AI Audio Production Engine jobs. */
model AudioJob {
  id                 String    @id @default(uuid())
  userId             String?
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId          String?
  project            Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  generationJobId    String?
  generationJob      GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)
  backendJobId       String?   @unique
  status             String    @default("queued")
  prompt             String?
  provider           String?
  engineVersion      String?
  durationSec        Float     @default(0)
  validationPassed   Boolean   @default(false)
  productionReady    Boolean   @default(false)
  exportReady        Boolean   @default(false)
  retryCount         Int       @default(0)
  queuePosition      Int?
  errorMessage       String?
  metadata           Json?
  timeline           Json?
  observability      Json?
  version            Int       @default(1)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  completedAt        DateTime?

  voiceAssets        VoiceAsset[]
  musicAssets        MusicAsset[]
  soundEffects       SoundEffectAsset[]
  timelineMeta       AudioTimelineMeta[]
  history            AudioGenerationHistory[]
  voiceJobs          VoiceJob[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([backendJobId])
}

model VoiceAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  text         String?
  character    String?
  language     String    @default("en")
  startSec     Float     @default(0)
  endSec       Float     @default(0)
  providerHint String?
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
  @@index([clipId])
}

model MusicAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  style        String?
  mood         String?
  startSec     Float     @default(0)
  endSec       Float     @default(0)
  loop         Boolean   @default(false)
  providerHint String?
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model SoundEffectAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  label        String?
  category     String?
  startSec     Float     @default(0)
  durationSec  Float     @default(0.5)
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model AudioTimelineMeta {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  trackId      String
  kind         String
  gainDb       Float     @default(0)
  clips        Json?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model AudioGenerationHistory {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  version      Int       @default(1)
  status       String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([audioJobId, createdAt(sort: Desc)])
}

/** Phase 4 Sprint 2 — Voice Generation Engine */
model VoiceJob {
  id                  String    @id @default(uuid())
  userId              String?
  user                User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  audioJobId          String?
  audioJob            AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: SetNull)
  backendJobId        String?   @unique
  status              String    @default("queued")
  text                String
  language            String    @default("en")
  voiceId             String
  gender              String?
  provider            String?
  voiceModel          String?
  speed               Float     @default(1)
  pitch               Float     @default(0)
  volume              Float     @default(1)
  pauseMs             Int       @default(0)
  ssml                String?
  estimatedDurationSec Float    @default(0)
  qualityScore        Float?
  qualityGrade        String?
  assetUrl            String?
  productionReady     Boolean   @default(false)
  exportReady         Boolean   @default(false)
  retryCount          Int       @default(0)
  queuePosition       Int?
  errorMessage        String?
  version             Int       @default(1)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  completedAt         DateTime?

  profiles            VoiceProfile[]
  synthAssets         VoiceSynthAsset[]
  metaRecords         VoiceMeta[]
  historyEntries      VoiceHistoryEntry[]
  versions            VoiceVersion[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([language])
  @@index([backendJobId])
}

model VoiceProfile {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  voiceId      String
  name         String?
  language     String
  gender       String?
  style        String?
  providerModel String?
  sampleRate   Int       @default(24000)
  tags         Json?
  createdAt    DateTime  @default(now())

  @@index([voiceId])
  @@index([language])
  @@index([voiceJobId])
}

model VoiceSynthAsset {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  format       String    @default("wav")
  assetUrl     String?
  filename     String?
  bytes        Int?
  checksum     String?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId])
}

model VoiceMeta {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  key          String
  value        Json?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId, key])
}

model VoiceHistoryEntry {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  status       String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId, createdAt(sort: Desc)])
}

model VoiceVersion {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  version      Int
  ssml         String?
  assetUrl     String?
  qualityScore Float?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId, version])
}

// ---------------------------------------------------------------------------
// Phase 4 Sprint 3 — Voice Cloning & Character Voice
// ---------------------------------------------------------------------------

model VoiceClone {
  id                   String    @id @default(uuid())
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  backendCloneId       String?   @unique
  status               String    @default("queued")
  characterId          String?
  referenceUrl         String
  referenceChecksum    String?
  language             String    @default("en")
  accent               String    @default("neutral")
  speakingStyle        String    @default("natural")
  emotionProfile       String    @default("calm")
  gender               String?
  ageGroup             String?
  voiceLocked          Boolean   @default(false)
  voiceVersion         Int       @default(1)
  provider             String?
  qualityScore         Float?
  qualityGrade         String?
  speakerVerified      Boolean   @default(false)
  previewUrl           String?
  assetUrl             String?
  productionReady      Boolean   @default(false)
  retryCount           Int       @default(0)
  queuePosition        Int?
  errorMessage         String?
  trainingDurationMs   Float?
  processingTimeMs     Float?
  parentGenerationId   String?
  parentVideoJobId     String?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  characterVoices      CharacterVoice[]
  fingerprints         VoiceFingerprint[]
  cloneMeta            VoiceCloneMeta[]
  cloneVersions        VoiceCloneVersion[]
  trainingHistory      VoiceTrainingHistory[]
  speakerProfiles      SpeakerProfile[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([characterId])
  @@index([backendCloneId])
}

model CharacterVoice {
  id              String    @id @default(uuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  characterId     String
  voiceCloneId    String?
  voiceClone      VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: SetNull)
  defaultVoice    String
  language        String    @default("en")
  accent          String    @default("neutral")
  speakingStyle   String    @default("natural")
  emotionProfile  String    @default("calm")
  gender          String?
  ageGroup        String?
  voiceVersion    Int       @default(1)
  voiceLocked     Boolean   @default(false)
  speakerId       String?
  previewUrl      String?
  voiceMetadata   Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([characterId])
  @@index([userId])
  @@index([voiceCloneId])
  @@index([defaultVoice])
}

model SpeakerProfile {
  id              String    @id @default(uuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  voiceCloneId    String?
  voiceClone      VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  backendSpeakerId String?  @unique
  gender          String?
  ageGroup        String?
  language        String    @default("en")
  accent          String    @default("neutral")
  speakingStyle   String    @default("natural")
  emotionProfile  String    @default("calm")
  locked          Boolean   @default(false)
  version         Int       @default(1)
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fingerprints    VoiceFingerprint[]

  @@index([userId])
  @@index([voiceCloneId])
  @@index([backendSpeakerId])
}

model VoiceFingerprint {
  id              String    @id @default(uuid())
  voiceCloneId    String?
  voiceClone      VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  speakerProfileId String?
  speakerProfile  SpeakerProfile? @relation(fields: [speakerProfileId], references: [id], onDelete: SetNull)
  fingerprintId   String    @unique
  checksum        String
  embeddingRef    String?
  sampleRate      Int       @default(24000)
  durationSec     Float     @default(0)
  spectralHash    String?
  speakerScore    Float?
  createdAt       DateTime  @default(now())

  @@index([voiceCloneId])
  @@index([checksum])
  @@index([speakerProfileId])
}

model VoiceCloneMeta {
  id           String    @id @default(uuid())
  voiceCloneId String?
  voiceClone   VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  key          String
  value        Json?
  createdAt    DateTime  @default(now())

  @@index([voiceCloneId, key])
}

model VoiceCloneVersion {
  id           String    @id @default(uuid())
  voiceCloneId String?
  voiceClone   VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  version      Int
  assetUrl     String?
  previewUrl   String?
  qualityScore Float?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([voiceCloneId, version])
}

model VoiceTrainingHistory {
  id                  String    @id @default(uuid())
  voiceCloneId        String?
  voiceClone          VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  version             Int
  trainingDurationMs  Float?
  provider            String?
  qualityScore        Float?
  status              String?
  snapshot            Json?
  createdAt           DateTime  @default(now())

  @@index([voiceCloneId, createdAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// Phase 4 Sprint 4 — Music Generation & Composition
// ---------------------------------------------------------------------------

model MusicJob {
  id                   String    @id @default(uuid())
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  backendJobId         String?   @unique
  status               String    @default("queued")
  genre                String    @default("cinematic")
  role                 String    @default("background")
  title                String?
  bpm                  Int       @default(90)
  keySignature         String?   @map("key")
  mood                 String?
  energy               Float     @default(0.6)
  intensity            Float     @default(0.5)
  durationSec          Float     @default(30)
  instruments          Json?
  loop                 Boolean   @default(false)
  fadeInSec            Float     @default(1)
  fadeOutSec           Float     @default(2)
  stems                Json?
  assetUrl             String?
  previewUrl           String?
  stemUrls             Json?
  libraryId            String?
  provider             String?
  musicVersion         Int       @default(1)
  productionReady      Boolean   @default(false)
  retryCount           Int       @default(0)
  queuePosition        Int?
  errorMessage         String?
  sceneEmotion         String?
  sceneDurationSec     Float?
  cameraMotion         String?
  storyBeat            String?
  parentAudioJobId     String?
  parentVideoJobId     String?
  parentGenerationId   String?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  compositionAssets    MusicCompositionAsset[]
  libraryEntries       MusicLibraryEntry[]
  metaRecords          MusicMeta[]
  versions             MusicCompositionVersion[]
  historyEntries       MusicHistoryEntry[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([genre])
  @@index([backendJobId])
  @@index([libraryId])
}

model MusicCompositionAsset {
  id           String    @id @default(uuid())
  musicJobId   String?
  musicJob     MusicJob? @relation(fields: [musicJobId], references: [id], onDelete: Cascade)
  format       String    @default("wav")
  assetUrl     String?
  filename     String?
  stemName     String?
  bytes        Int?
  checksum     String?
  createdAt    DateTime  @default(now())

  @@index([musicJobId])
}

model MusicLibraryEntry {
  id           String    @id @default(uuid())
  musicJobId   String?
  musicJob     MusicJob? @relation(fields: [musicJobId], references: [id], onDelete: SetNull)
  libraryId    String    @unique
  title        String?
  genre        String
  role         String
  bpm          Int?
  keySignature String?   @map("key")
  mood         String?
  durationSec  Float?
  instruments  Json?
  loop         Boolean   @default(false)
  assetUrl     String?
  previewUrl   String?
  musicVersion Int       @default(1)
  tags         Json?
  createdAt    DateTime  @default(now())

  @@index([genre])
  @@index([role])
  @@index([musicJobId])
}

model MusicMeta {
  id           String    @id @default(uuid())
  musicJobId   String?
  musicJob     MusicJob? @relation(fields: [musicJobId], references: [id], onDelete: Cascade)
  key          String
  value        Json?
  createdAt    DateTime  @default(now())

  @@index([musicJobId, key])
}

model MusicCompositionVersion {
  id           String    @id @default(uuid())
  musicJobId   String?
  musicJob     MusicJob? @relation(fields: [musicJobId], references: [id], onDelete: Cascade)
  version      Int
  genre        String?
  bpm          Int?
  assetUrl     String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([musicJobId, version])
}

model MusicHistoryEntry {
  id           String    @id @default(uuid())
  musicJobId   String?
  musicJob     MusicJob? @relation(fields: [musicJobId], references: [id], onDelete: Cascade)
  status       String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([musicJobId, createdAt(sort: Desc)])
}

model GenreLibrary {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  defaultBpm    Int       @default(90)
  defaultMood   String?
  defaultEnergy Float     @default(0.6)
  defaultKey    String?
  tags          Json?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([active])
}

model InstrumentLibrary {
  id           String    @id @default(uuid())
  code         String    @unique
  name         String
  family       String?
  genres       Json?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@index([family])
  @@index([active])
}

// ---------------------------------------------------------------------------
// Phase 4 Sprint 5 — Sound Effects & Ambient Audio
// ---------------------------------------------------------------------------

model SfxJob {
  id                   String    @id @default(uuid())
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  backendJobId         String?   @unique
  status               String    @default("queued")
  kind                 String    @default("scene")
  categories           Json?
  environment          String?
  mood                 String?
  energy               Float     @default(0.5)
  sceneId              String?
  durationSec          Float     @default(12)
  volume               Float     @default(0.5)
  loop                 Boolean   @default(false)
  fadeInSec            Float     @default(0.5)
  fadeOutSec           Float     @default(1)
  assetUrl             String?
  previewUrl           String?
  libraryIds           Json?
  provider             String?
  audioVersion         Int       @default(1)
  productionReady      Boolean   @default(false)
  retryCount           Int       @default(0)
  queuePosition        Int?
  errorMessage         String?
  parentAudioJobId     String?
  parentMusicJobId     String?
  parentVideoJobId     String?
  parentGenerationId   String?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  ambientAssets        AmbientAsset[]
  sfxLibraryEntries    SfxLibraryEntry[]
  environmentProfiles  EnvironmentProfile[]
  audioLayers          AudioLayer[]
  timelineEvents       SfxTimelineEvent[]
  metaRecords          SfxAssetMeta[]
  historyEntries       SfxHistoryEntry[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([kind])
  @@index([environment])
  @@index([backendJobId])
  @@index([sceneId])
}

model AmbientAsset {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  category     String
  kind         String    @default("ambient")
  assetUrl     String?
  filename     String?
  durationSec  Float?
  loop         Boolean   @default(true)
  volume       Float     @default(0.5)
  checksum     String?
  createdAt    DateTime  @default(now())

  @@index([sfxJobId])
  @@index([category])
}

model SfxLibraryEntry {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: SetNull)
  libraryId    String    @unique
  category     String
  kind         String
  environment  String?
  durationSec  Float?
  loop         Boolean   @default(false)
  volume       Float?
  assetUrl     String?
  audioVersion Int       @default(1)
  tags         Json?
  createdAt    DateTime  @default(now())

  @@index([category])
  @@index([kind])
  @@index([sfxJobId])
}

model EnvironmentProfile {
  id                      String    @id @default(uuid())
  sfxJobId                String?
  sfxJob                  SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  environment             String
  mood                    String?
  energy                  Float     @default(0.5)
  sceneId                 String?
  recommendedCategories   Json?
  metadata                Json?
  createdAt               DateTime  @default(now())

  @@index([environment])
  @@index([sfxJobId])
  @@index([sceneId])
}

model AudioLayer {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  layerId      String
  category     String
  kind         String
  volume       Float     @default(0.5)
  startSec     Float     @default(0)
  endSec       Float     @default(0)
  loop         Boolean   @default(false)
  fadeInSec    Float     @default(0.5)
  fadeOutSec   Float     @default(1)
  spatial      Json?
  assetUrl     String?
  libraryId    String?
  createdAt    DateTime  @default(now())

  @@index([sfxJobId])
  @@index([layerId])
  @@index([category])
}

model SfxTimelineEvent {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  eventId      String
  sceneId      String?
  atSec        Float     @default(0)
  category     String
  action       String
  layerId      String?
  metadata     Json?
  createdAt    DateTime  @default(now())

  @@index([sfxJobId, atSec])
  @@index([sceneId])
  @@index([eventId])
}

model SfxAssetMeta {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  key          String
  value        Json?
  createdAt    DateTime  @default(now())

  @@index([sfxJobId, key])
}

model SfxHistoryEntry {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  status       String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([sfxJobId, createdAt(sort: Desc)])
}

model SfxCategoryLibrary {
  id              String    @id @default(uuid())
  code            String    @unique
  name            String
  kind            String    @default("sfx")
  defaultVolume   Float     @default(0.5)
  loopable        Boolean   @default(false)
  tags            Json?
  moodAffinity    Json?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@index([kind])
  @@index([active])
}
