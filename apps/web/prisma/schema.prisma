  mentions CollabMention[]

  @@index([organizationId, resourceType, resourceId, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([isPinned])
  @@index([deletedAt])
}

model CollabCommentReply {
  id        String   @id @default(uuid())
  commentId String
  comment   CollabComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("CollabCommentReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
