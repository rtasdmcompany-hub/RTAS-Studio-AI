datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  image         String?
  provider      String   @default("credentials")
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Studio profile & SaaS generation limits
  tier                   String    @default("free")
  credits                Int       @default(50)
  concurrentTracks       Int       @default(0)
  creditsExpireAt        DateTime?
  subscriptionActive     Boolean   @default(false)
  subscriptionRenewsAt   DateTime?
  freeTrialUsed          Boolean   @default(false)
  hasUsedFreeTrial       Boolean   @default(false)
  previewSkipsRemaining  Int       @default(3)
  paymentProvider        String?
  externalCustomerId     String?
  externalSubscriptionId String?

  generationJobs GenerationJob[]
  projects       Project[]
  audioJobs      AudioJob[]
  voiceJobs      VoiceJob[]
  voiceClones    VoiceClone[]
  characterVoices CharacterVoice[]
  speakerProfiles SpeakerProfile[]
  musicJobs      MusicJob[]
  sfxJobs        SfxJob[]
  mixJobs        AudioMixJob[]
  localizationJobs LocalizationJob[]
  timelineJobs   TimelineJob[]
}

/** Durable studio project — every generation creates/updates one. */
model Project {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  prompt          String?
  inputImageUrl   String?
  audioUrl        String?
  settings        Json?
  durationSeconds Int      @default(0)
  creditsUsed     Int      @default(0)
  provider        String?
  outputUrl       String?
  status          String   @default("queued")
  latestJobId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  generationJobs GenerationJob[]
  audioJobs      AudioJob[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
}

model GenerationJob {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId         String?
  project           Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status            GenerationJobStatus @default(QUEUED)
  prompt            String?
  inputImageUrl     String?
  audioUrl          String?
  generatedVideoUrl String?
  durationSeconds   Int                 @default(0)
  creditsCharged    Int                 @default(0)
  creditsDebited    Boolean             @default(false)
  provider          String?
  settings          Json?
  progressPercent   Int                 @default(0)
  stageLabel        String?
  queuePosition     Int?
  estimatedSecondsRemaining Int?
  retryCount        Int                 @default(0)
  chunkTotal        Int?
  chunksCompleted   Int?
  chunkManifest     Json?
  errorMessage      String?
  backendJobId      String?
  isPublic          Boolean             @default(false)
  shareTitle        String?
  publishedAt       DateTime?
  startedAt         DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  completedAt       DateTime?

  audioJobs         AudioJob[]

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([projectId])
  @@index([isPublic])
}

enum GenerationJobStatus {
  QUEUED
  PREPARING
  GENERATING
  GENERATING_CHUNKS
  RENDERING
  COMPILING_MEDIA
  UPLOADING
  COMPLETED
  FAILED
  CANCELLED
}

/** Phase 4 — AI Audio Production Engine jobs. */
model AudioJob {
  id                 String    @id @default(uuid())
  userId             String?
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId          String?
  project            Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  generationJobId    String?
  generationJob      GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)
  backendJobId       String?   @unique
  status             String    @default("queued")
  prompt             String?
  provider           String?
  engineVersion      String?
  durationSec        Float     @default(0)
  validationPassed   Boolean   @default(false)
  productionReady    Boolean   @default(false)
  exportReady        Boolean   @default(false)
  retryCount         Int       @default(0)
  queuePosition      Int?
  errorMessage       String?
  metadata           Json?
  timeline           Json?
  observability      Json?
  version            Int       @default(1)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  completedAt        DateTime?

  voiceAssets        VoiceAsset[]
  musicAssets        MusicAsset[]
  soundEffects       SoundEffectAsset[]
  timelineMeta       AudioTimelineMeta[]
  history            AudioGenerationHistory[]
  voiceJobs          VoiceJob[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([backendJobId])
}

model VoiceAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  text         String?
  character    String?
  language     String    @default("en")
  startSec     Float     @default(0)
  endSec       Float     @default(0)
  providerHint String?
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
  @@index([clipId])
}

model MusicAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  style        String?
  mood         String?
  startSec     Float     @default(0)
  endSec       Float     @default(0)
  loop         Boolean   @default(false)
  providerHint String?
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model SoundEffectAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  label        String?
  category     String?
  startSec     Float     @default(0)
  durationSec  Float     @default(0.5)
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model AudioTimelineMeta {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  trackId      String
  kind         String
  gainDb       Float     @default(0)
  clips        Json?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model AudioGenerationHistory {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  version      Int       @default(1)
  status       String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([audioJobId, createdAt(sort: Desc)])
}

/** Phase 4 Sprint 2 — Voice Generation Engine */
model VoiceJob {
  id                  String    @id @default(uuid())
  userId              String?
  user                User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  audioJobId          String?
  audioJob            AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: SetNull)
  backendJobId        String?   @unique
  status              String    @default("queued")
  text                String
  language            String    @default("en")
  voiceId             String
  gender              String?
  provider            String?
  voiceModel          String?
  speed               Float     @default(1)
  pitch               Float     @default(0)
  volume              Float     @default(1)
  pauseMs             Int       @default(0)
  ssml                String?
  estimatedDurationSec Float    @default(0)
  qualityScore        Float?
  qualityGrade        String?
  assetUrl            String?
  productionReady     Boolean   @default(false)
  exportReady         Boolean   @default(false)
  retryCount          Int       @default(0)
  queuePosition       Int?
  errorMessage        String?
  version             Int       @default(1)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  completedAt         DateTime?

  profiles            VoiceProfile[]
  synthAssets         VoiceSynthAsset[]
  metaRecords         VoiceMeta[]
  historyEntries      VoiceHistoryEntry[]
  versions            VoiceVersion[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([language])
  @@index([backendJobId])
}

model VoiceProfile {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  voiceId      String
  name         String?
  language     String
  gender       String?
  style        String?
  providerModel String?
  sampleRate   Int       @default(24000)
  tags         Json?
  createdAt    DateTime  @default(now())

  @@index([voiceId])
  @@index([language])
  @@index([voiceJobId])
}

model VoiceSynthAsset {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  format       String    @default("wav")
  assetUrl     String?
  filename     String?
  bytes        Int?
  checksum     String?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId])
}

model VoiceMeta {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  key          String
  value        Json?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId, key])
}

model VoiceHistoryEntry {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  status       String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId, createdAt(sort: Desc)])
}

model VoiceVersion {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  version      Int
  ssml         String?
  assetUrl     String?
  qualityScore Float?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId, version])
}

// ---------------------------------------------------------------------------
// Phase 4 Sprint 3 — Voice Cloning & Character Voice
// ---------------------------------------------------------------------------

model VoiceClone {
  id                   String    @id @default(uuid())
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  backendCloneId       String?   @unique
  status               String    @default("queued")
  characterId          String?
  referenceUrl         String
  referenceChecksum    String?
  language             String    @default("en")
  accent               String    @default("neutral")
  speakingStyle        String    @default("natural")
  emotionProfile       String    @default("calm")
  gender               String?
  ageGroup             String?
  voiceLocked          Boolean   @default(false)
  voiceVersion         Int       @default(1)
  provider             String?
  qualityScore         Float?
  qualityGrade         String?
  speakerVerified      Boolean   @default(false)
  previewUrl           String?
  assetUrl             String?
  productionReady      Boolean   @default(false)
  retryCount           Int       @default(0)
  queuePosition        Int?
  errorMessage         String?
  trainingDurationMs   Float?
  processingTimeMs     Float?
  parentGenerationId   String?
  parentVideoJobId     String?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  characterVoices      CharacterVoice[]
  fingerprints         VoiceFingerprint[]
  cloneMeta            VoiceCloneMeta[]
  cloneVersions        VoiceCloneVersion[]
  trainingHistory      VoiceTrainingHistory[]
  speakerProfiles      SpeakerProfile[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([characterId])
  @@index([backendCloneId])
}

model CharacterVoice {
  id              String    @id @default(uuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  characterId     String
  voiceCloneId    String?
  voiceClone      VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: SetNull)
  defaultVoice    String
  language        String    @default("en")
  accent          String    @default("neutral")
  speakingStyle   String    @default("natural")
  emotionProfile  String    @default("calm")
  gender          String?
  ageGroup        String?
  voiceVersion    Int       @default(1)
  voiceLocked     Boolean   @default(false)
  speakerId       String?
  previewUrl      String?
  voiceMetadata   Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([characterId])
  @@index([userId])
  @@index([voiceCloneId])
  @@index([defaultVoice])
}

model SpeakerProfile {
  id              String    @id @default(uuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  voiceCloneId    String?
  voiceClone      VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  backendSpeakerId String?  @unique
  gender          String?
  ageGroup        String?
  language        String    @default("en")
  accent          String    @default("neutral")
  speakingStyle   String    @default("natural")
  emotionProfile  String    @default("calm")
  locked          Boolean   @default(false)
  version         Int       @default(1)
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fingerprints    VoiceFingerprint[]

  @@index([userId])
  @@index([voiceCloneId])
  @@index([backendSpeakerId])
}

model VoiceFingerprint {
  id              String    @id @default(uuid())
  voiceCloneId    String?
  voiceClone      VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  speakerProfileId String?
  speakerProfile  SpeakerProfile? @relation(fields: [speakerProfileId], references: [id], onDelete: SetNull)
  fingerprintId   String    @unique
  checksum        String
  embeddingRef    String?
  sampleRate      Int       @default(24000)
  durationSec     Float     @default(0)
  spectralHash    String?
  speakerScore    Float?
  createdAt       DateTime  @default(now())

  @@index([voiceCloneId])
  @@index([checksum])
  @@index([speakerProfileId])
}

model VoiceCloneMeta {
  id           String    @id @default(uuid())
  voiceCloneId String?
  voiceClone   VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  key          String
  value        Json?
  createdAt    DateTime  @default(now())

  @@index([voiceCloneId, key])
}

model VoiceCloneVersion {
  id           String    @id @default(uuid())
  voiceCloneId String?
  voiceClone   VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  version      Int
  assetUrl     String?
  previewUrl   String?
  qualityScore Float?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([voiceCloneId, version])
}

model VoiceTrainingHistory {
  id                  String    @id @default(uuid())
  voiceCloneId        String?
  voiceClone          VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  version             Int
  trainingDurationMs  Float?
  provider            String?
  qualityScore        Float?
  status              String?
  snapshot            Json?
  createdAt           DateTime  @default(now())

  @@index([voiceCloneId, createdAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// Phase 4 Sprint 4 — Music Generation & Composition
// ---------------------------------------------------------------------------

model MusicJob {
  id                   String    @id @default(uuid())
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  backendJobId         String?   @unique
  status               String    @default("queued")
  genre                String    @default("cinematic")
  role                 String    @default("background")
  title                String?
  bpm                  Int       @default(90)
  keySignature         String?   @map("key")
  mood                 String?
  energy               Float     @default(0.6)
  intensity            Float     @default(0.5)
  durationSec          Float     @default(30)
  instruments          Json?
  loop                 Boolean   @default(false)
  fadeInSec            Float     @default(1)
  fadeOutSec           Float     @default(2)
  stems                Json?
  assetUrl             String?
  previewUrl           String?
  stemUrls             Json?
  libraryId            String?
  provider             String?
  musicVersion         Int       @default(1)
  productionReady      Boolean   @default(false)
  retryCount           Int       @default(0)
  queuePosition        Int?
  errorMessage         String?
  sceneEmotion         String?
  sceneDurationSec     Float?
  cameraMotion         String?
  storyBeat            String?
  parentAudioJobId     String?
  parentVideoJobId     String?
  parentGenerationId   String?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  compositionAssets    MusicCompositionAsset[]
  libraryEntries       MusicLibraryEntry[]
  metaRecords          MusicMeta[]
  versions             MusicCompositionVersion[]
  historyEntries       MusicHistoryEntry[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([genre])
  @@index([backendJobId])
  @@index([libraryId])
}

model MusicCompositionAsset {
  id           String    @id @default(uuid())
  musicJobId   String?
  musicJob     MusicJob? @relation(fields: [musicJobId], references: [id], onDelete: Cascade)
  format       String    @default("wav")
  assetUrl     String?
  filename     String?
  stemName     String?
  bytes        Int?
  checksum     String?
  createdAt    DateTime  @default(now())

  @@index([musicJobId])
}

model MusicLibraryEntry {
  id           String    @id @default(uuid())
  musicJobId   String?
  musicJob     MusicJob? @relation(fields: [musicJobId], references: [id], onDelete: SetNull)
  libraryId    String    @unique
  title        String?
  genre        String
  role         String
  bpm          Int?
  keySignature String?   @map("key")
  mood         String?
  durationSec  Float?
  instruments  Json?
  loop         Boolean   @default(false)
  assetUrl     String?
  previewUrl   String?
  musicVersion Int       @default(1)
  tags         Json?
  createdAt    DateTime  @default(now())

  @@index([genre])
  @@index([role])
  @@index([musicJobId])
}

model MusicMeta {
  id           String    @id @default(uuid())
  musicJobId   String?
  musicJob     MusicJob? @relation(fields: [musicJobId], references: [id], onDelete: Cascade)
  key          String
  value        Json?
  createdAt    DateTime  @default(now())

  @@index([musicJobId, key])
}

model MusicCompositionVersion {
  id           String    @id @default(uuid())
  musicJobId   String?
  musicJob     MusicJob? @relation(fields: [musicJobId], references: [id], onDelete: Cascade)
  version      Int
  genre        String?
  bpm          Int?
  assetUrl     String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([musicJobId, version])
}

model MusicHistoryEntry {
  id           String    @id @default(uuid())
  musicJobId   String?
  musicJob     MusicJob? @relation(fields: [musicJobId], references: [id], onDelete: Cascade)
  status       String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([musicJobId, createdAt(sort: Desc)])
}

model GenreLibrary {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  defaultBpm    Int       @default(90)
  defaultMood   String?
  defaultEnergy Float     @default(0.6)
  defaultKey    String?
  tags          Json?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([active])
}

model InstrumentLibrary {
  id           String    @id @default(uuid())
  code         String    @unique
  name         String
  family       String?
  genres       Json?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@index([family])
  @@index([active])
}

// ---------------------------------------------------------------------------
// Phase 4 Sprint 5 — Sound Effects & Ambient Audio
// ---------------------------------------------------------------------------

model SfxJob {
  id                   String    @id @default(uuid())
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  backendJobId         String?   @unique
  status               String    @default("queued")
  kind                 String    @default("scene")
  categories           Json?
  environment          String?
  mood                 String?
  energy               Float     @default(0.5)
  sceneId              String?
  durationSec          Float     @default(12)
  volume               Float     @default(0.5)
  loop                 Boolean   @default(false)
  fadeInSec            Float     @default(0.5)
  fadeOutSec           Float     @default(1)
  assetUrl             String?
  previewUrl           String?
  libraryIds           Json?
  provider             String?
  audioVersion         Int       @default(1)
  productionReady      Boolean   @default(false)
  retryCount           Int       @default(0)
  queuePosition        Int?
  errorMessage         String?
  parentAudioJobId     String?
  parentMusicJobId     String?
  parentVideoJobId     String?
  parentGenerationId   String?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  ambientAssets        AmbientAsset[]
  sfxLibraryEntries    SfxLibraryEntry[]
  environmentProfiles  EnvironmentProfile[]
  audioLayers          AudioLayer[]
  timelineEvents       SfxTimelineEvent[]
  metaRecords          SfxAssetMeta[]
  historyEntries       SfxHistoryEntry[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([kind])
  @@index([environment])
  @@index([backendJobId])
  @@index([sceneId])
}

model AmbientAsset {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  category     String
  kind         String    @default("ambient")
  assetUrl     String?
  filename     String?
  durationSec  Float?
  loop         Boolean   @default(true)
  volume       Float     @default(0.5)
  checksum     String?
  createdAt    DateTime  @default(now())

  @@index([sfxJobId])
  @@index([category])
}

model SfxLibraryEntry {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: SetNull)
  libraryId    String    @unique
  category     String
  kind         String
  environment  String?
  durationSec  Float?
  loop         Boolean   @default(false)
  volume       Float?
  assetUrl     String?
  audioVersion Int       @default(1)
  tags         Json?
  createdAt    DateTime  @default(now())

  @@index([category])
  @@index([kind])
  @@index([sfxJobId])
}

model EnvironmentProfile {
  id                      String    @id @default(uuid())
  sfxJobId                String?
  sfxJob                  SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  environment             String
  mood                    String?
  energy                  Float     @default(0.5)
  sceneId                 String?
  recommendedCategories   Json?
  metadata                Json?
  createdAt               DateTime  @default(now())

  @@index([environment])
  @@index([sfxJobId])
  @@index([sceneId])
}

model AudioLayer {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  layerId      String
  category     String
  kind         String
  volume       Float     @default(0.5)
  startSec     Float     @default(0)
  endSec       Float     @default(0)
  loop         Boolean   @default(false)
  fadeInSec    Float     @default(0.5)
  fadeOutSec   Float     @default(1)
  spatial      Json?
  assetUrl     String?
  libraryId    String?
  createdAt    DateTime  @default(now())

  @@index([sfxJobId])
  @@index([layerId])
  @@index([category])
}

model SfxTimelineEvent {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  eventId      String
  sceneId      String?
  atSec        Float     @default(0)
  category     String
  action       String
  layerId      String?
  metadata     Json?
  createdAt    DateTime  @default(now())

  @@index([sfxJobId, atSec])
  @@index([sceneId])
  @@index([eventId])
}

model SfxAssetMeta {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  key          String
  value        Json?
  createdAt    DateTime  @default(now())

  @@index([sfxJobId, key])
}

model SfxHistoryEntry {
  id           String    @id @default(uuid())
  sfxJobId     String?
  sfxJob       SfxJob?   @relation(fields: [sfxJobId], references: [id], onDelete: Cascade)
  status       String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([sfxJobId, createdAt(sort: Desc)])
}

model SfxCategoryLibrary {
  id              String    @id @default(uuid())
  code            String    @unique
  name            String
  kind            String    @default("sfx")
  defaultVolume   Float     @default(0.5)
  loopable        Boolean   @default(false)
  tags            Json?
  moodAffinity    Json?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@index([kind])
  @@index([active])
}

// ---------------------------------------------------------------------------
// Phase 4 Sprint 6 — Mixing & Mastering
// ---------------------------------------------------------------------------

model AudioMixJob {
  id                   String    @id @default(uuid())
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  backendJobId         String?   @unique
  status               String    @default("queued")
  kind                 String    @default("mix_master")
  mixJobId             String?
  masterJobId          String?
  targetLufs           Float     @default(-14)
  truePeakCeiling      Float     @default(-1)
  integratedLufs       Float?
  truePeakDbtp         Float?
  qualityScore         Float?
  qualityGrade         String?
  clarityScore         Float?
  stereoWidth          Float?
  productionReady      Boolean   @default(false)
  assetUrl             String?
  masterUrl            String?
  exportFormat         String    @default("wav")
  exportSampleRate     Int       @default(48000)
  exportBitDepth       Int       @default(24)
  provider             String?
  audioVersion         Int       @default(1)
  retryCount           Int       @default(0)
  queuePosition        Int?
  errorMessage         String?
  parentVoiceJobId     String?
  parentMusicJobId     String?
  parentSfxJobId       String?
  parentAudioJobId     String?
  parentVideoJobId     String?
  parentGenerationId   String?
  mixProfile           Json?
  masterProfile        Json?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  masteringJobs        MasteringJob[]
  mixProfiles          MixProfileRecord[]
  masterProfiles       MasterProfileRecord[]
  loudnessReports      LoudnessReport[]
  frequencyAnalyses    FrequencyAnalysis[]
  qualityReports       AudioQualityReport[]
  exportMetadata       MixExportMetadata[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([kind])
  @@index([backendJobId])
  @@index([mixJobId])
  @@index([masterJobId])
}

model MasteringJob {
  id              String    @id @default(uuid())
  audioMixJobId   String?
  audioMixJob     AudioMixJob? @relation(fields: [audioMixJobId], references: [id], onDelete: Cascade)
  backendMasterId String?   @unique
  status          String    @default("queued")
  targetLufs      Float     @default(-14)
  truePeakCeiling Float     @default(-1)
  masterUrl       String?
  qualityScore    Float?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([audioMixJobId])
  @@index([backendMasterId])
}

model MixProfileRecord {
  id              String    @id @default(uuid())
  audioMixJobId   String?
  audioMixJob     AudioMixJob? @relation(fields: [audioMixJobId], references: [id], onDelete: Cascade)
  dialoguePriority Boolean  @default(true)
  musicDuckingDb  Float     @default(-8)
  sfxBalance      Float     @default(0.75)
  ambientLevel    Float     @default(0.45)
  compressionRatio Float    @default(3)
  profile         Json?
  createdAt       DateTime  @default(now())

  @@index([audioMixJobId])
}

model MasterProfileRecord {
  id                    String    @id @default(uuid())
  audioMixJobId         String?
  audioMixJob           AudioMixJob? @relation(fields: [audioMixJobId], references: [id], onDelete: Cascade)
  targetLufs            Float     @default(-14)
  truePeakCeilingDbtp   Float     @default(-1)
  stereoWidth           Float     @default(1.15)
  noiseReduction        Boolean   @default(true)
  profile               Json?
  createdAt             DateTime  @default(now())

  @@index([audioMixJobId])
}

model LoudnessReport {
  id               String    @id @default(uuid())
  audioMixJobId    String?
  audioMixJob      AudioMixJob? @relation(fields: [audioMixJobId], references: [id], onDelete: Cascade)
  integratedLufs   Float
  shortTermLufs    Float?
  momentaryLufs    Float?
  truePeakDbtp     Float?
  peakDbfs         Float?
  loudnessRangeLu  Float?
  normalized       Boolean   @default(false)
  createdAt        DateTime  @default(now())

  @@index([audioMixJobId])
}

model FrequencyAnalysis {
  id                  String    @id @default(uuid())
  audioMixJobId       String?
  audioMixJob         AudioMixJob? @relation(fields: [audioMixJobId], references: [id], onDelete: Cascade)
  lowEnergy           Float?
  midEnergy           Float?
  highEnergy          Float?
  spectralCentroidHz  Float?
  tonalBalanceScore   Float?
  bands               Json?
  createdAt           DateTime  @default(now())

  @@index([audioMixJobId])
}

model AudioQualityReport {
  id               String    @id @default(uuid())
  audioMixJobId    String?
  audioMixJob      AudioMixJob? @relation(fields: [audioMixJobId], references: [id], onDelete: Cascade)
  lufs             Float?
  peakDbfs         Float?
  truePeakDbtp     Float?
  dynamicRangeDb   Float?
  stereoWidth      Float?
  noiseFloorDb     Float?
  frequencyBalance Float?
  clarityScore     Float?
  overallScore     Float?
  grade            String?
  productionReady  Boolean   @default(false)
  notes            Json?
  createdAt        DateTime  @default(now())

  @@index([audioMixJobId])
  @@index([overallScore])
}

model MixExportMetadata {
  id               String    @id @default(uuid())
  audioMixJobId    String?
  audioMixJob      AudioMixJob? @relation(fields: [audioMixJobId], references: [id], onDelete: Cascade)
  format           String    @default("wav")
  sampleRate       Int       @default(48000)
  bitDepth         Int       @default(24)
  masterUrl        String?
  assetUrl         String?
  metadata         Json?
  createdAt        DateTime  @default(now())

  @@index([audioMixJobId])
}

// ---------------------------------------------------------------------------
// Phase 4 Sprint 7 — Multi-Language Dubbing & Localization
// ---------------------------------------------------------------------------

model LocalizationJob {
  id                   String    @id @default(uuid())
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  backendJobId         String?   @unique
  status               String    @default("queued")
  kind                 String    @default("localize")
  sourceLanguage       String    @default("en")
  targetLanguage       String
  sourceText           String
  translatedText       String?
  accentProfile        String?
  voicePreserved       Boolean   @default(true)
  speakerCount         Int       @default(1)
  subtitleUrl          String?
  captionUrl           String?
  dubbedAudioUrl       String?
  provider             String?
  localizationVersion  Int       @default(1)
  productionReady      Boolean   @default(false)
  retryCount           Int       @default(0)
  queuePosition        Int?
  errorMessage         String?
  parentVoiceJobId     String?
  parentCloneId        String?
  parentVideoJobId     String?
  parentGenerationId   String?
  lipSyncMetadata      Json?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  languageProfiles     LanguageProfileRecord[]
  subtitleAssets       SubtitleAsset[]
  captionAssets        CaptionAsset[]
  speakerMaps          SpeakerMap[]
  translationMemory    TranslationMemoryEntry[]
  localizationHistory  LocalizationHistoryEntry[]
  audioTracks          LocalizationAudioTrack[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([sourceLanguage, targetLanguage])
  @@index([backendJobId])
}

model LanguageProfileRecord {
  id              String    @id @default(uuid())
  localizationJobId String?
  localizationJob LocalizationJob? @relation(fields: [localizationJobId], references: [id], onDelete: Cascade)
  code            String
  name            String?
  rtl             Boolean   @default(false)
  defaultLocale   String?
  accentDefault   String?
  script          String?
  createdAt       DateTime  @default(now())

  @@index([code])
  @@index([localizationJobId])
}

model SubtitleAsset {
  id                String    @id @default(uuid())
  localizationJobId String?
  localizationJob   LocalizationJob? @relation(fields: [localizationJobId], references: [id], onDelete: Cascade)
  language          String
  format            String    @default("vtt")
  assetUrl          String?
  cueCount          Int       @default(0)
  cues              Json?
  createdAt         DateTime  @default(now())

  @@index([localizationJobId])
  @@index([language])
}

model CaptionAsset {
  id                String    @id @default(uuid())
  localizationJobId String?
  localizationJob   LocalizationJob? @relation(fields: [localizationJobId], references: [id], onDelete: Cascade)
  language          String
  format            String    @default("vtt")
  assetUrl          String?
  cueCount          Int       @default(0)
  cues              Json?
  createdAt         DateTime  @default(now())

  @@index([localizationJobId])
  @@index([language])
}

model SpeakerMap {
  id                String    @id @default(uuid())
  localizationJobId String?
  localizationJob   LocalizationJob? @relation(fields: [localizationJobId], references: [id], onDelete: Cascade)
  speakerId         String
  characterId       String?
  sourceVoiceId     String?
  cloneId           String?
  gender            String?
  accent            String?
  preserved         Boolean   @default(true)
  createdAt         DateTime  @default(now())

  @@index([localizationJobId])
  @@index([speakerId])
  @@index([characterId])
}

model TranslationMemoryEntry {
  id                String    @id @default(uuid())
  localizationJobId String?
  localizationJob   LocalizationJob? @relation(fields: [localizationJobId], references: [id], onDelete: SetNull)
  sourceLanguage    String
  targetLanguage    String
  sourceTextHash    String
  sourceText        String
  translatedText    String
  hitCount          Int       @default(1)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([sourceLanguage, targetLanguage, sourceTextHash])
  @@index([localizationJobId])
}

model LocalizationHistoryEntry {
  id                String    @id @default(uuid())
  localizationJobId String?
  localizationJob   LocalizationJob? @relation(fields: [localizationJobId], references: [id], onDelete: Cascade)
  status            String?
  snapshot          Json?
  createdAt         DateTime  @default(now())

  @@index([localizationJobId, createdAt(sort: Desc)])
}

model LocalizationAudioTrack {
  id                String    @id @default(uuid())
  localizationJobId String?
  localizationJob   LocalizationJob? @relation(fields: [localizationJobId], references: [id], onDelete: Cascade)
  trackId           String
  language          String
  kind              String    @default("dialogue")
  assetUrl          String?
  durationSec       Float     @default(0)
  speakerId         String?
  createdAt         DateTime  @default(now())

  @@index([localizationJobId])
  @@index([language])
  @@index([trackId])
}

model LocalizationLanguageCatalog {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  nativeName    String?
  rtl           Boolean   @default(false)
  defaultLocale String?
  accentDefault String?
  script        String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([active])
}

// ---------------------------------------------------------------------------
// Phase 4 Sprint 8 — Audio Timeline & Cinematic Synchronization
// ---------------------------------------------------------------------------

model TimelineJob {
  id                       String    @id @default(uuid())
  userId                   String?
  user                     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  backendJobId             String?   @unique
  status                   String    @default("queued")
  fps                      Float     @default(24)
  durationSec              Float     @default(0)
  trackCount               Int       @default(0)
  sceneCount               Int       @default(0)
  shotCount                Int       @default(0)
  beatCount                Int       @default(0)
  syncAccuracy             Float     @default(0)
  locked                   Boolean   @default(false)
  snapEnabled              Boolean   @default(true)
  autoAlign                Boolean   @default(true)
  productionReady          Boolean   @default(false)
  exportUrl                String?
  masterTimelineUrl        String?
  provider                 String?
  timelineVersion          Int       @default(1)
  retryCount               Int       @default(0)
  queuePosition            Int?
  errorMessage             String?
  parentVoiceJobId         String?
  parentMusicJobId         String?
  parentSfxJobId           String?
  parentMixJobId           String?
  parentLocalizationJobId  String?
  parentVideoJobId         String?
  parentGenerationId       String?
  metadata                 Json?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  completedAt              DateTime?

  tracks        TimelineTrackRecord[]
  events        TimelineEventRecord[]
  audioLayers   AudioLayerRecord[]
  syncMetadata  SyncMetadataRecord[]
  beatMarkers   BeatMarkerRecord[]
  history       TimelineHistoryEntry[]
  versions      TimelineVersionRecord[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([backendJobId])
  @@index([parentGenerationId])
}

model TimelineTrackRecord {
  id            String    @id @default(uuid())
  timelineJobId String?
  timelineJob   TimelineJob? @relation(fields: [timelineJobId], references: [id], onDelete: Cascade)
  trackId       String
  kind          String
  name          String?
  gainDb        Float     @default(0)
  muted         Boolean   @default(false)
  locked        Boolean   @default(false)
  snapEnabled   Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())

  @@index([timelineJobId])
  @@index([trackId])
  @@index([kind])
}

model TimelineEventRecord {
  id            String    @id @default(uuid())
  timelineJobId String?
  timelineJob   TimelineJob? @relation(fields: [timelineJobId], references: [id], onDelete: Cascade)
  eventId       String
  trackId       String
  kind          String
  startSec      Float     @default(0)
  endSec        Float     @default(0)
  label         String?
  sceneId       String?
  shotId        String?
  frame         Int?
  emotion       String?
  assetUrl      String?
  gainDb        Float     @default(0)
  locked        Boolean   @default(false)
  metadata      Json?
  createdAt     DateTime  @default(now())

  @@index([timelineJobId])
  @@index([trackId])
  @@index([sceneId])
  @@index([shotId])
}

model AudioLayerRecord {
  id            String    @id @default(uuid())
  timelineJobId String?
  timelineJob   TimelineJob? @relation(fields: [timelineJobId], references: [id], onDelete: Cascade)
  layerId       String
  name          String
  trackIds      Json?
  blendMode     String    @default("mix")
  gainDb        Float     @default(0)
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([timelineJobId])
  @@index([layerId])
}

model SyncMetadataRecord {
  id                   String    @id @default(uuid())
  timelineJobId        String?
  timelineJob          TimelineJob? @relation(fields: [timelineJobId], references: [id], onDelete: Cascade)
  mode                 String    @default("auto")
  fps                  Float     @default(24)
  frameAccuracyMs      Float     @default(0)
  syncAccuracy         Float     @default(0)
  sceneCount           Int       @default(0)
  shotCount            Int       @default(0)
  beatCount            Int       @default(0)
  lipSyncAligned       Boolean   @default(false)
  emotionAligned       Boolean   @default(false)
  cameraMusicAligned   Boolean   @default(false)
  dynamicBalance       Boolean   @default(true)
  snapGridMs           Float     @default(33.33)
  details              Json?
  createdAt            DateTime  @default(now())

  @@index([timelineJobId])
}

model BeatMarkerRecord {
  id            String    @id @default(uuid())
  timelineJobId String?
  timelineJob   TimelineJob? @relation(fields: [timelineJobId], references: [id], onDelete: Cascade)
  markerId      String
  timeSec       Float
  beatIndex     Int       @default(0)
  intensity     Float     @default(0.5)
  bar           Int?
  createdAt     DateTime  @default(now())

  @@index([timelineJobId])
  @@index([timeSec])
}

model TimelineHistoryEntry {
  id            String    @id @default(uuid())
  timelineJobId String?
  timelineJob   TimelineJob? @relation(fields: [timelineJobId], references: [id], onDelete: Cascade)
  status        String?
  snapshot      Json?
  createdAt     DateTime  @default(now())

  @@index([timelineJobId, createdAt(sort: Desc)])
}

model TimelineVersionRecord {
  id            String    @id @default(uuid())
  timelineJobId String?
  timelineJob   TimelineJob? @relation(fields: [timelineJobId], references: [id], onDelete: Cascade)
  version       Int
  label         String?
  snapshot      Json?
  createdAt     DateTime  @default(now())

  @@index([timelineJobId, version])
}
