  storageUrl String?
  sizeBytes  Int      @default(0)
  checksum   String?
  note       String?
  createdById String
  createdAt  DateTime @default(now())

  @@unique([assetId, version])
  @@index([assetId, createdAt(sort: Desc)])
}

model LibraryAssetMetadata {
  id        String   @id @default(uuid())
  assetId   String   @unique
  asset     LibraryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  title     String?
  description String?
  width     Int?
  height    Int?
  durationSec Float?
  language  String?
  attributesJson Json?
  embeddingHint String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LibraryAssetTag {
  id        String   @id @default(uuid())
  assetId   String
  asset     LibraryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag       String
  createdAt DateTime @default(now())

  @@unique([assetId, tag])
  @@index([tag])
}

model LibraryAssetCategory {
  id             String   @id @default(uuid())
  organizationId String?
  key            String
  name           String
  description    String?
  isSystem       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@unique([organizationId, key])
  @@index([key])
}

model LibraryAssetPermission {
  id        String   @id @default(uuid())
  assetId   String
  asset     LibraryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  subjectType String
  subjectId String
  role      String   @default("read")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assetId, subjectType, subjectId])
  @@index([subjectType, subjectId])
  @@index([userId])
}

model LibraryAssetActivity {
  id        String   @id @default(uuid())
  assetId   String
  asset     LibraryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  actorId   String
  action    String
  detail    String?
  metadataJson Json?
  createdAt DateTime @default(now())

  @@index([assetId, createdAt(sort: Desc)])
  @@index([actorId])
  @@index([action])
}

model LibraryAssetCollection {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  name           String
  slug           String
  libraryScope   String   @default("organization")
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

