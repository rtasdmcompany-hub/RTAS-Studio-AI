// ---------------------------------------------------------------------------
// Phase 7 Sprint 7 — Enterprise Version Control, Approval & Review Engine
// ---------------------------------------------------------------------------

model OrgProjectVersion {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  projectId      String
  project        OrgProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionNumber  Int
  label          String?
  notes          String?
  status         String   @default("draft")
  createdById    String
  createdBy      User     @relation("OrgProjectVersionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  parentVersionId String?
  isCurrent      Boolean  @default(false)
  snapshotJson   Json?
  metadataJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  snapshots VersionSnapshot[]
  approvals OrgProjectApprovalRequest[]
  reviews   OrgProjectReview[]
  rollbacksFrom OrgProjectRollbackHistory[] @relation("RollbackFromVersion")
  rollbacksTo   OrgProjectRollbackHistory[] @relation("RollbackToVersion")

  @@unique([projectId, versionNumber])
  @@index([organizationId, projectId, createdAt(sort: Desc)])
  @@index([workspaceId])
  @@index([status])
  @@index([isCurrent])
}

model VersionSnapshot {
  id           String   @id @default(uuid())
  versionId    String
  version      OrgProjectVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  name         String?
  payloadJson  Json
  checksum     String?
  sizeBytes    Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([versionId, createdAt(sort: Desc)])
}

model OrgProjectApprovalRequest {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  projectId      String
  project        OrgProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId      String?
  version        OrgProjectVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  requestedById  String
  requestedBy    User     @relation("OrgProjectApprovalRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewerId     String?
  reviewer       User?    @relation("OrgProjectApprovalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  status         String   @default("pending_review")
  scope          String   @default("internal")
  title          String?
  notes          String?
  decidedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  history OrgProjectApprovalHistory[]
  reviews OrgProjectReview[]

  @@index([organizationId, projectId, createdAt(sort: Desc)])
  @@index([status])
  @@index([reviewerId])
  @@index([versionId])
}

model OrgProjectApprovalHistory {
  id          String   @id @default(uuid())
  approvalId  String
  approval    OrgProjectApprovalRequest @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User     @relation("OrgProjectApprovalHistoryActor", fields: [actorId], references: [id], onDelete: Cascade)
  fromStatus  String?
  toStatus    String
  note        String?
  createdAt   DateTime @default(now())

  @@index([approvalId, createdAt(sort: Desc)])
  @@index([actorId])
}

model OrgProjectReview {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  projectId      String
  project        OrgProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId      String?
  version        OrgProjectVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  approvalId     String?
  approval       OrgProjectApprovalRequest? @relation(fields: [approvalId], references: [id], onDelete: SetNull)
  createdById    String
  createdBy      User     @relation("OrgProjectReviewCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assigneeId     String?
  assignee       User?    @relation("OrgProjectReviewAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reviewType     String   @default("internal")
