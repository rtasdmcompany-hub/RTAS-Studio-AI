  author         User     @relation("CollabCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  resourceType   String
  resourceId     String
  body           String
  isPinned       Boolean  @default(false)
  isResolved     Boolean  @default(false)
  reactionsJson  Json?
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
