datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  image         String?
  provider      String   @default("credentials")
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Studio profile & SaaS generation limits
  tier                   String    @default("free")
  credits                Int       @default(50)
  concurrentTracks       Int       @default(0)
  creditsExpireAt        DateTime?
  subscriptionActive     Boolean   @default(false)
  subscriptionRenewsAt   DateTime?
  freeTrialUsed          Boolean   @default(false)
  hasUsedFreeTrial       Boolean   @default(false)
  previewSkipsRemaining  Int       @default(3)
  paymentProvider        String?
  externalCustomerId     String?
  externalSubscriptionId String?

  generationJobs GenerationJob[]
  projects       Project[]
  audioJobs      AudioJob[]
}

/** Durable studio project — every generation creates/updates one. */
model Project {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  prompt          String?
  inputImageUrl   String?
  audioUrl        String?
  settings        Json?
  durationSeconds Int      @default(0)
  creditsUsed     Int      @default(0)
  provider        String?
  outputUrl       String?
  status          String   @default("queued")
  latestJobId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  generationJobs GenerationJob[]
  audioJobs      AudioJob[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
}

model GenerationJob {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId         String?
  project           Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status            GenerationJobStatus @default(QUEUED)
  prompt            String?
  inputImageUrl     String?
  audioUrl          String?
  generatedVideoUrl String?
  durationSeconds   Int                 @default(0)
  creditsCharged    Int                 @default(0)
  creditsDebited    Boolean             @default(false)
  provider          String?
  settings          Json?
  progressPercent   Int                 @default(0)
  stageLabel        String?
  queuePosition     Int?
  estimatedSecondsRemaining Int?
  retryCount        Int                 @default(0)
  chunkTotal        Int?
  chunksCompleted   Int?
  chunkManifest     Json?
  errorMessage      String?
  backendJobId      String?
  isPublic          Boolean             @default(false)
  shareTitle        String?
  publishedAt       DateTime?
  startedAt         DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  completedAt       DateTime?

  audioJobs         AudioJob[]

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([projectId])
  @@index([isPublic])
}

enum GenerationJobStatus {
  QUEUED
  PREPARING
  GENERATING
  GENERATING_CHUNKS
  RENDERING
  COMPILING_MEDIA
  UPLOADING
  COMPLETED
  FAILED
  CANCELLED
}

/** Phase 4 — AI Audio Production Engine jobs. */
model AudioJob {
  id                 String    @id @default(uuid())
  userId             String?
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId          String?
  project            Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  generationJobId    String?
  generationJob      GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)
  backendJobId       String?   @unique
  status             String    @default("queued")
  prompt             String?
  provider           String?
  engineVersion      String?
  durationSec        Float     @default(0)
  validationPassed   Boolean   @default(false)
  productionReady    Boolean   @default(false)
  exportReady        Boolean   @default(false)
  retryCount         Int       @default(0)
  queuePosition      Int?
  errorMessage       String?
  metadata           Json?
  timeline           Json?
  observability      Json?
  version            Int       @default(1)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  completedAt        DateTime?

  voiceAssets        VoiceAsset[]
  musicAssets        MusicAsset[]
  soundEffects       SoundEffectAsset[]
  timelineMeta       AudioTimelineMeta[]
  history            AudioGenerationHistory[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([backendJobId])
}

model VoiceAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  text         String?
  character    String?
  language     String    @default("en")
  startSec     Float     @default(0)
  endSec       Float     @default(0)
  providerHint String?
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
  @@index([clipId])
}

model MusicAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  style        String?
  mood         String?
  startSec     Float     @default(0)
  endSec       Float     @default(0)
  loop         Boolean   @default(false)
  providerHint String?
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model SoundEffectAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  label        String?
  category     String?
  startSec     Float     @default(0)
  durationSec  Float     @default(0.5)
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model AudioTimelineMeta {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  trackId      String
  kind         String
  gainDb       Float     @default(0)
  clips        Json?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model AudioGenerationHistory {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  version      Int       @default(1)
  status       String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([audioJobId, createdAt(sort: Desc)])
}
