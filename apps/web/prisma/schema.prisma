datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  image         String?
  provider      String   @default("credentials")
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Studio profile & SaaS generation limits
  tier                   String    @default("free")
  credits                Int       @default(50)
  concurrentTracks       Int       @default(0)
  creditsExpireAt        DateTime?
  subscriptionActive     Boolean   @default(false)
  subscriptionRenewsAt   DateTime?
  freeTrialUsed          Boolean   @default(false)
  hasUsedFreeTrial       Boolean   @default(false)
  previewSkipsRemaining  Int       @default(3)
  paymentProvider        String?
  externalCustomerId     String?
  externalSubscriptionId String?

  generationJobs GenerationJob[]
  projects       Project[]
}

/** Durable studio project — every generation creates/updates one. */
model Project {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  prompt          String?
  inputImageUrl   String?
  audioUrl        String?
  settings        Json?
  durationSeconds Int      @default(0)
  creditsUsed     Int      @default(0)
  provider        String?
  outputUrl       String?
  status          String   @default("queued")
  latestJobId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  generationJobs GenerationJob[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
}

model GenerationJob {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId         String?
  project           Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status            GenerationJobStatus @default(QUEUED)
  prompt            String?
  inputImageUrl     String?
  audioUrl          String?
  generatedVideoUrl String?
  durationSeconds   Int                 @default(0)
  creditsCharged    Int                 @default(0)
  creditsDebited    Boolean             @default(false)
  provider          String?
  settings          Json?
  progressPercent   Int                 @default(0)
  stageLabel        String?
  queuePosition     Int?
  estimatedSecondsRemaining Int?
  retryCount        Int                 @default(0)
  chunkTotal        Int?
  chunksCompleted   Int?
  chunkManifest     Json?
  errorMessage      String?
  backendJobId      String?
  isPublic          Boolean             @default(false)
  shareTitle        String?
  publishedAt       DateTime?
  startedAt         DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  completedAt       DateTime?

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([projectId])
  @@index([isPublic])
}

enum GenerationJobStatus {
  QUEUED
  PREPARING
  GENERATING
  GENERATING_CHUNKS
  RENDERING
  COMPILING_MEDIA
  UPLOADING
  COMPLETED
  FAILED
  CANCELLED
}
