  metadata    LibraryAssetMetadata?
  tags        LibraryAssetTag[]
  permissions LibraryAssetPermission[]
  activity    LibraryAssetActivity[]
  collections LibraryAssetCollectionItem[]

  @@unique([organizationId, slug])
  @@index([organizationId, assetType, createdAt(sort: Desc)])
