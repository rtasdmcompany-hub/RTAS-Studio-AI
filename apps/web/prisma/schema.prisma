  mentionsJson   Json?
  status         String   @default("visible")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([subjectId])
  @@index([authorUserId])
  @@index([parentId])
  @@index([status])
  @@map("Comments")
}

/** Like on an asset. */
model Like {
  id                String   @id @default(uuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assetId           String
  userId            String
  assetCategory     String   @default("")
  assetOwnerUserId  String   @default("")
  createdAt         DateTime @default(now())

  @@unique([organizationId, assetId, userId])
  @@index([organizationId])
  @@index([assetId])
  @@index([assetOwnerUserId])
  @@map("Likes")
}

/** Favorite or bookmark of an asset (kind: favorite | bookmark). */
model Favorite {
  id                String   @id @default(uuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assetId           String
  userId            String
  kind              String   @default("favorite")
  assetCategory     String   @default("")
  assetOwnerUserId  String   @default("")
  createdAt         DateTime @default(now())

  @@unique([organizationId, assetId, userId, kind])
  @@index([organizationId])
  @@index([userId, kind])
  @@index([assetId])
  @@map("Favorites")
}

/** Community notification (follow, review, comment, reply, mention, like, featured). */
model Notification {
  id              String   @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipientUserId String
  type            String
  actorUserId     String   @default("")
  subjectId       String   @default("")
  message         String   @default("")
  read            Boolean  @default(false)
  readAt          DateTime?
  createdAt       DateTime @default(now())

  @@index([organizationId, recipientUserId, read])
  @@index([recipientUserId, createdAt(sort: Desc)])
  @@map("Notifications")
}

// --- Phase 9 Sprint 4 — Template Store, Versioning & Asset Management ---
// Reuses AssetCategory ("AssetCategories"), AssetTag ("AssetTags") and
// AssetCollection ("AssetCollections") from Phase 9 Sprint 1.

/** Template asset in the enterprise template store. */
model Template {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerUserId    String
  name           String
  slug           String
  templateType   String   @default("custom")
  description    String   @default("")
  category       String   @default("other")
  tagsJson       Json?
  status         String   @default("active")
  featured       Boolean  @default(false)
  currentVersion String   @default("1.0.0")
  assetUri       String   @default("")
  libraryId      String?
  library        AssetLibrary? @relation(fields: [libraryId], references: [id], onDelete: SetNull)
  downloads      Int      @default(0)
  ratingTotal    Int      @default(0)
  ratingCount    Int      @default(0)
  metadataJson   Json?
  archivedAt     DateTime?
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  versions       TemplateVersion[]
  searchIndex    AssetSearchIndex?

  @@index([organizationId])
  @@index([ownerUserId])
  @@index([status])
  @@index([templateType])
  @@index([category])
  @@index([featured])
  @@index([libraryId])
  @@map("Templates")
}

/** Immutable version record with integrity checksum. */
model TemplateVersion {
  id         String   @id @default(uuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version    String
  changelog  String   @default("")
  assetUri   String   @default("")
  checksum   String   @default("")
  createdBy  String   @default("")
  createdAt  DateTime @default(now())

  @@unique([templateId, version])
  @@index([templateId, createdAt(sort: Desc)])
  @@map("TemplateVersions")
}

/** Asset library grouping templates inside an organization. */
model AssetLibrary {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerUserId    String
  name           String
  slug           String
  description    String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  templates      Template[]

  @@index([organizationId])
  @@index([ownerUserId])
  @@map("AssetLibraries")
}

/** Full-text search index entry for a template. */
model AssetSearchIndex {
  id             String   @id @default(uuid())
  templateId     String   @unique
  template       Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  organizationId String
  tokensJson     Json?
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("AssetSearchIndex")
}

// ---------------------------------------------------------------------------
// Phase 9 Sprint 5 — Plugin Framework, Extension SDK & Third-Party Integrations
// ---------------------------------------------------------------------------

/** Registered enterprise plugin in the organization catalog. */
model Plugin {
  id                  String   @id @default(uuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerUserId         String
  name                String
  slug                String
  pluginType          String   @default("custom")
  description         String   @default("")
  status              String   @default("registered")
  currentVersion      String   @default("1.0.0")
  manifestJson        Json?
  signature           String   @default("")
  publisherKey        String   @default("")
  minPlatformVersion  String   @default("1.0.0")
  maxPlatformVersion  String   @default("99.99.99")
  sandboxReady        Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  versions            PluginVersion[]
  installations       InstalledPlugin[]
  permissions         PluginPermission[]
  events              PluginEvent[]

  @@index([organizationId])
  @@index([ownerUserId])
  @@index([pluginType])
  @@index([status])
  @@index([slug])
  @@map("Plugins")
}

/** Immutable plugin version with signature and compatibility metadata. */
model PluginVersion {
  id               String   @id @default(uuid())
  pluginId         String
  plugin           Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  version          String
  changelog        String   @default("")
  manifestJson     Json?
  signature        String   @default("")
  checksum         String   @default("")
  compatibilityJson Json?
  createdBy        String   @default("")
  createdAt        DateTime @default(now())

  @@unique([pluginId, version])
  @@index([pluginId, createdAt(sort: Desc)])
  @@map("PluginVersions")
}

/** Plugin installation scoped to organization and optional workspace. */
model InstalledPlugin {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  pluginId       String
  plugin         Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  version        String
  status         String   @default("installed")
  installedBy    String   @default("")
  configId       String?
  installedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
  permissions    PluginPermission[]
  configuration  PluginConfiguration?

  @@unique([organizationId, pluginId, workspaceId])
  @@index([organizationId])
  @@index([workspaceId])
  @@index([pluginId])
  @@index([status])
  @@map("InstalledPlugins")
}

/** Permission grant isolated per plugin installation. */
model PluginPermission {
  id             String   @id @default(uuid())
  pluginId       String
  plugin         Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  installedId    String
  installation   InstalledPlugin @relation(fields: [installedId], references: [id], onDelete: Cascade)
  permissionKey  String
  scope          String   @default("organization")
  granted        Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([pluginId])
  @@index([installedId])
  @@index([permissionKey])
  @@map("PluginPermissions")
}

/** Runtime configuration for an installed plugin (secrets by ref only). */
model PluginConfiguration {
  id          String   @id @default(uuid())
  installedId String   @unique
  installation InstalledPlugin @relation(fields: [installedId], references: [id], onDelete: Cascade)
  configJson  Json?
  secretsRef  String   @default("")
  updatedAt   DateTime @updatedAt

  @@map("PluginConfigurations")
}

/** Third-party integration connection (Drive, Slack, Zapier, webhooks, etc.). */
model IntegrationConnection {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  provider       String
  status         String   @default("connected")
  displayName    String   @default("")
  credentialsRef String   @default("")
  metadataJson   Json?
  connectedBy    String   @default("")
  connectedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
  logs           IntegrationLog[]

  @@index([organizationId])
  @@index([workspaceId])
  @@index([provider])
  @@index([status])
  @@map("IntegrationConnections")
}

/** Audit / activity log for an integration connection. */
model IntegrationLog {
  id           String   @id @default(uuid())
  connectionId String
  connection   IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  eventType    String
  message      String   @default("")
  success      Boolean  @default(true)
  metadataJson Json?
  createdAt    DateTime @default(now())

  @@index([connectionId, createdAt(sort: Desc)])
  @@index([eventType])
  @@map("IntegrationLogs")
}

/** Plugin event bus record (lifecycle, config, integration channels). */
model PluginEvent {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pluginId       String?
  plugin         Plugin?  @relation(fields: [pluginId], references: [id], onDelete: SetNull)
  eventType      String
  channel        String   @default("plugin.lifecycle")
  payloadJson    Json?
  actorUserId    String   @default("")
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([pluginId])
  @@index([channel])
  @@index([eventType])
  @@map("PluginEvents")
}

// ---------------------------------------------------------------------------
// Phase 9 Sprint 6 — Public API Platform, SDK & Developer Ecosystem
// ---------------------------------------------------------------------------

/** Developer portal account bound to a user + organization. */
model DeveloperAccount {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  displayName    String
  email          String   @default("")
  status         String   @default("active")
  company        String   @default("")
  website        String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  applications   ApiApplication[]
  oauthClients   OAuthClient[]
  apiTokens      ApiToken[]
  usageLogs      ApiUsageLog[]
  webhooks       WebhookSubscription[]

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([status])
  @@map("DeveloperAccounts")
}

/** API application registered by a developer. */
model ApiApplication {
  id             String   @id @default(uuid())
  developerId    String
  developer      DeveloperAccount @relation(fields: [developerId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  description    String   @default("")
  status         String   @default("active")
  homepageUrl    String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  oauthClients   OAuthClient[]
  apiTokens      ApiToken[]
  webhooks       WebhookSubscription[]

  @@index([developerId])
  @@index([organizationId])
  @@index([slug])
  @@map("ApiApplications")
}

/** OAuth 2.0 client credentials with redirect URIs and scopes. */
model OAuthClient {
  id               String   @id @default(uuid())
  developerId      String
  developer        DeveloperAccount @relation(fields: [developerId], references: [id], onDelete: Cascade)
  applicationId    String
  application      ApiApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId         String   @unique
  clientSecretHash String
  name             String
  redirectUrisJson Json?
  grantTypesJson   Json?
  scopesJson       Json?
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([developerId])
  @@index([applicationId])
  @@index([organizationId])
  @@index([status])
  @@map("OAuthClients")
}

/** Hashed API token / key for public API access. */
model ApiToken {
  id                 String    @id @default(uuid())
  developerId        String
  developer          DeveloperAccount @relation(fields: [developerId], references: [id], onDelete: Cascade)
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applicationId      String?
  application        ApiApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  workspaceId        String?
  name               String
  tokenPrefix        String
  tokenHash          String    @unique
  scopesJson         Json?
  status             String    @default("active")
  rateLimitPerMinute Int       @default(120)
  lastUsedAt         DateTime?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  revokedAt          DateTime?
  usageLogs          ApiUsageLog[]

  @@index([developerId])
  @@index([organizationId])
  @@index([workspaceId])
  @@index([status])
  @@map("ApiTokens")
}

/** Published public API version metadata. */
model ApiVersion {
  id               String    @id @default(uuid())
  version          String    @unique
  status           String    @default("active")
  changelog        String    @default("")
  deprecatedAt     DateTime?
  sunsetAt         DateTime?
  compatibilityJson Json?
  createdAt        DateTime  @default(now())

  @@index([status])
  @@map("ApiVersions")
}

/** Per-request usage log for developer analytics. */
model ApiUsageLog {
  id             String   @id @default(uuid())
  developerId    String
  developer      DeveloperAccount @relation(fields: [developerId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tokenId        String?
  token          ApiToken? @relation(fields: [tokenId], references: [id], onDelete: SetNull)
  clientId       String?
  surface        String
  method         String
  path           String
  statusCode     Int      @default(200)
  latencyMs      Float    @default(0)
  version        String   @default("v1")
  workspaceId    String?
  createdAt      DateTime @default(now())

  @@index([developerId, createdAt(sort: Desc)])
  @@index([organizationId])
  @@index([surface])
  @@index([tokenId])
  @@map("ApiUsageLogs")
}

/** SDK package release for a target language. */
model SdkRelease {
  id          String   @id @default(uuid())
  language    String
  version     String
  packageName String
  downloadUrl String   @default("")
  checksum    String   @default("")
  changelog   String   @default("")
  status      String   @default("published")
  createdAt   DateTime @default(now())

  @@unique([language, version])
  @@index([language])
  @@index([status])
  @@map("SdkReleases")
}

/** Developer webhook subscription for API events. */
model WebhookSubscription {
  id             String   @id @default(uuid())
  developerId    String
  developer      DeveloperAccount @relation(fields: [developerId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applicationId  String?
  application    ApiApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  targetUrl      String
  eventsJson     Json?
  secretHash     String   @default("")
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([developerId])
  @@index([organizationId])
  @@index([status])
  @@map("WebhookSubscriptions")
}

// ---------------------------------------------------------------------------
// Phase 9 Sprint 7 — AI Agents, Automation Workflows & Orchestration
// ---------------------------------------------------------------------------

/** Enterprise AI agent instance. */
model AIAgent {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  ownerUserId    String
  name           String
  slug           String
  agentType      String   @default("custom")
  description    String   @default("")
  status         String   @default("active")
  capabilitiesJson Json?
  configJson     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  memories       AgentMemory[]
  events         AgentEvent[]

  @@index([organizationId])
  @@index([workspaceId])
  @@index([ownerUserId])
  @@index([agentType])
  @@index([status])
  @@map("AIAgents")
}

/** Agent workflow definition with steps and trigger. */
model AgentWorkflow {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  ownerUserId    String
  name           String
  slug           String
  description    String   @default("")
  trigger        String   @default("manual")
  mode           String   @default("sequential")
  status         String   @default("active")
  stepsJson      Json?
  conditionsJson Json?
  templateId     String?
  template       AgentWorkflowTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  executions     WorkflowExecution[]
  scheduledJobs  ScheduledJob[]

  @@index([organizationId])
  @@index([workspaceId])
  @@index([status])
  @@index([templateId])
  @@map("AgentWorkflows")
}

/** Reusable agent workflow template. */
model AgentWorkflowTemplate {
  id             String   @id @default(uuid())
  slug           String   @unique
  name           String
  description    String   @default("")
  mode           String   @default("sequential")
  agentTypesJson Json?
  stepsJson      Json?
  createdAt      DateTime @default(now())
  workflows      AgentWorkflow[]

  @@map("AgentWorkflowTemplates")
}

/** Single workflow execution run. */
model WorkflowExecution {
  id             String    @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  workflowId     String
  workflow       AgentWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status         String    @default("queued")
  trigger        String    @default("manual")
  startedBy      String    @default("")
  contextJson    Json?
  resultsJson    Json?
  error          String    @default("")
  retries        Int       @default(0)
  maxRetries     Int       @default(3)
  priority       String    @default("normal")
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  history        ExecutionHistory[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([workflowId])
  @@index([status])
  @@map("WorkflowExecutions")
}

/** Key/value memory entry for an agent. */
model AgentMemory {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId        String
  agent          AIAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  workspaceId    String?
  key            String
  valueJson      Json?
  executionId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([agentId, key])
  @@index([organizationId])
  @@index([agentId])
  @@map("AgentMemory")
}

/** Scheduled workflow job. */
model ScheduledJob {
  id             String    @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  workflowId     String
  workflow       AgentWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  kind           String    @default("once")
  cron           String    @default("")
  priority       String    @default("normal")
  status         String    @default("scheduled")
  nextRunAt      DateTime?
  lastRunAt      DateTime?
  maxRetries     Int       @default(3)
  createdBy      String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([workflowId])
  @@index([status])
  @@index([nextRunAt])
  @@map("ScheduledJobs")
}

/** Execution history / audit trail events. */
model ExecutionHistory {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executionId    String
  execution      WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  workflowId     String
  eventType      String
  message        String   @default("")
  metadataJson   Json?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([executionId])
  @@index([workflowId])
  @@index([eventType])
  @@map("ExecutionHistory")
}

/** Agent lifecycle / task event. */
model AgentEvent {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId        String
  agent          AIAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  eventType      String
  payloadJson    Json?
  actorUserId    String   @default("")
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([agentId])
  @@index([eventType])
  @@map("AgentEvents")
}

// ---------------------------------------------------------------------------
// Phase 9 Sprint 8 — Enterprise Automation, Integrations & Event-Driven Platform
// ---------------------------------------------------------------------------

/** Automation rule definition. */
model AutomationRule {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  ownerUserId    String
  name           String
  slug           String
  mode           String   @default("event")
  status         String   @default("active")
  description    String   @default("")
  triggerEvent   String   @default("")
  conditionsJson Json?
  actionsJson    Json?
  integrationId  String?
  priority       Int      @default(100)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  executions     AutomationExecution[]
  subscriptions  EventSubscription[]
  schedules      ScheduledAutomation[]
  history        AutomationHistory[]

  @@index([organizationId])
  @@index([workspaceId])
  @@index([status])
  @@index([triggerEvent])
  @@map("AutomationRules")
}

/** Automation execution instance. */
model AutomationExecution {
  id             String    @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  ruleId         String
  rule           AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  eventId        String?
  status         String    @default("queued")
  trigger        String    @default("event")
  resultsJson    Json?
  error          String    @default("")
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([ruleId])
  @@index([status])
  @@map("AutomationExecutions")
}

/** Event bus message (table EventBus). */
model EventBusEntry {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  eventType      String
  category       String
  payloadJson    Json?
  actorUserId    String   @default("")
  signature      String   @default("")
  status         String   @default("published")
  createdAt      DateTime @default(now())
  logs           EventLog[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([eventType])
  @@index([category])
  @@map("EventBus")
}

/** Per-event processing log. */
model EventLog {
  id             String   @id @default(uuid())
  eventId        String
  event          EventBusEntry @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  action         String
  message        String   @default("")
  success        Boolean  @default(true)
  metadataJson   Json?
  createdAt      DateTime @default(now())

  @@index([eventId, createdAt(sort: Desc)])
  @@index([organizationId])
  @@index([action])
  @@map("EventLogs")
}

/** Subscription linking an event type to an automation rule. */
model EventSubscription {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  eventType      String
  ruleId         String?
  rule           AutomationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  target         String   @default("automation")
  status         String   @default("active")
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([eventType])
  @@index([ruleId])
  @@map("EventSubscriptions")
}

/**
 * Automation-scoped integration connection.
 * Distinct from Sprint 5 plugin IntegrationConnections table.
 */
model AutomationIntegrationConnection {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  provider       String
  status         String   @default("connected")
  displayName    String   @default("")
  credentialsRef String   @default("")
  webhookSecret  String   @default("")
  metadataJson   Json?
  connectedBy    String   @default("")
  connectedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([workspaceId])
  @@index([provider])
  @@index([status])
  @@map("AutomationIntegrationConnections")
}

/** Scheduled automation job. */
model ScheduledAutomation {
  id             String    @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  ruleId         String
  rule           AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  kind           String    @default("once")
  cron           String    @default("")
  status         String    @default("scheduled")
  nextRunAt      DateTime?
  lastRunAt      DateTime?
  createdBy      String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([ruleId])
  @@index([status])
  @@index([nextRunAt])
  @@map("ScheduledAutomations")
}

/** Automation history / audit trail. */
model AutomationHistory {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ruleId         String
  rule           AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  executionId    String?
  eventType      String
  message        String   @default("")
  metadataJson   Json?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([ruleId])
  @@index([eventType])
  @@map("AutomationHistory")
}

/** Phase 9 Sprint 9 — Aggregated revenue report (org/workspace/period). */
