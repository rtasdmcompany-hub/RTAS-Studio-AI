  visibility   String   @default("private")
  defaultModel String?
  settingsJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/** Activity / audit trail for teams (and org/workspace scoped events). */
model TeamActivityLog {
