  author    User     @relation("OrgProjectReviewCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewId, createdAt(sort: Asc)])
  @@index([authorId])
}

model OrgProjectChangeLog {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  projectId      String
  project        OrgProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorId        String?
