  @@index([organizationId, projectId, createdAt(sort: Desc)])
  @@index([assigneeId])
  @@index([status])
  @@index([reviewType])
}

model OrgProjectReviewComment {
  id        String   @id @default(uuid())
  reviewId  String
  review    OrgProjectReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
