// ---------------------------------------------------------------------------
// Phase 5 Sprint 1 — AI Avatar & Character Generation Engine
// ---------------------------------------------------------------------------

model AvatarCharacterJob {
  id                   String    @id @default(uuid())
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  backendJobId         String?   @unique
  characterId          String
  uniqueId             String?
  registrySlot         String?
  status               String    @default("queued")
  name                 String?
  templateId           String?
  characterVersion     Int       @default(1)
  gender               String?
  age                  Int?
  ethnicity            String?
  bodyType             String?
  hairstyle            String?
  beard                String?
  skin                 String?
  eyeColor             String?
  clothing             String?
  accessories          Json?
  dnaFingerprint       String?
  dnaJson              Json?
  previewUrl           String?
  dnaUrl               String?
  productionReady      Boolean   @default(false)
  paddleVerified       Boolean   @default(false)
  provider             String?
  parentGenerationId   String?
  retryCount           Int       @default(0)
  errorMessage         String?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  dnaRecords AvatarCharacterDNA[]
  history    AvatarCharacterHistory[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([characterId])
  @@index([registrySlot])
  @@index([backendJobId])
  @@index([status])
}

model AvatarCharacterDNA {
  id                 String    @id @default(uuid())
  avatarCharacterJobId String?
  avatarCharacterJob AvatarCharacterJob? @relation(fields: [avatarCharacterJobId], references: [id], onDelete: Cascade)
  characterId        String
  dnaId              String
  version            Int       @default(1)
  fingerprint        String?
  locked             Boolean   @default(true)
  payload            Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([characterId])
  @@index([dnaId])
  @@index([avatarCharacterJobId])
}

model AvatarCharacterHistory {
  id                   String    @id @default(uuid())
  avatarCharacterJobId String?
  avatarCharacterJob   AvatarCharacterJob? @relation(fields: [avatarCharacterJobId], references: [id], onDelete: Cascade)
  status               String?
  snapshot             Json?
  createdAt            DateTime  @default(now())

  @@index([avatarCharacterJobId, createdAt(sort: Desc)])
}

model AvatarCharacterRegistry {
  id           String    @id @default(uuid())
  slot         String    @unique
  characterId  String?
  uniqueId     String?
  name         String?
  snapshot     Json?
  active       Boolean   @default(true)
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  @@index([characterId])
  @@index([active])
}

// ---------------------------------------------------------------------------
// Phase 5 Sprint 2 — AI Face Lock & Identity Engine
// ---------------------------------------------------------------------------

model FaceLockJob {
  id                   String    @id @default(uuid())
  userId               String?
  backendJobId         String?   @unique
  characterId          String
  lockId               String
  status               String    @default("locked")
  faceEmbeddingRef     String?
  identityStrength     Float     @default(0.95)
  identityScore        Float?
  driftDetected        Boolean   @default(false)
  featuresJson         Json?
  referenceUrl         String?
  referenceKind        String?
  version              Int       @default(1)
  productionReady      Boolean   @default(true)
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  embeddings FaceEmbeddingRecord[]
  verifications IdentityVerificationRecord[]
  references FaceReferenceRecord[]

  @@index([characterId])
  @@index([lockId])
  @@index([faceEmbeddingRef])
  @@index([status])
}

model FaceEmbeddingRecord {
  id               String    @id @default(uuid())
  faceLockJobId    String?
  faceLockJob      FaceLockJob? @relation(fields: [faceLockJobId], references: [id], onDelete: Cascade)
  characterId      String
  faceEmbeddingRef String
  dimension        Int       @default(64)
  locked           Boolean   @default(true)
  regenerated      Boolean   @default(false)
  vector           Json?
  createdAt        DateTime  @default(now())

  @@index([characterId])
  @@index([faceEmbeddingRef])
  @@index([faceLockJobId])
}

model IdentityVerificationRecord {
  id               String    @id @default(uuid())
  faceLockJobId    String?
  faceLockJob      FaceLockJob? @relation(fields: [faceLockJobId], references: [id], onDelete: Cascade)
  characterId      String
  identityScore    Float
  passed           Boolean   @default(false)
  driftDetected    Boolean   @default(false)
  cosineSimilarity Float?
  driftFlags       Json?
  notes            Json?
  createdAt        DateTime  @default(now())

  @@index([characterId, createdAt(sort: Desc)])
  @@index([faceLockJobId])
}

model FaceReferenceRecord {
  id            String    @id @default(uuid())
  faceLockJobId String?
  faceLockJob   FaceLockJob? @relation(fields: [faceLockJobId], references: [id], onDelete: Cascade)
  characterId   String
  referenceId   String
  kind          String
  url           String
  source        String?
  createdAt     DateTime  @default(now())

  @@index([characterId])
  @@index([kind])
  @@index([faceLockJobId])
}

