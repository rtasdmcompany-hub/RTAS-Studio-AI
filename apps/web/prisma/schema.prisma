datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  image         String?
  provider      String   @default("credentials")
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Studio profile & SaaS generation limits
  tier                   String    @default("free")
  credits                Int       @default(50)
  concurrentTracks       Int       @default(0)
  creditsExpireAt        DateTime?
  subscriptionActive     Boolean   @default(false)
  subscriptionRenewsAt   DateTime?
  freeTrialUsed          Boolean   @default(false)
  hasUsedFreeTrial       Boolean   @default(false)
  previewSkipsRemaining  Int       @default(3)
  paymentProvider        String?
  externalCustomerId     String?
  externalSubscriptionId String?

  generationJobs GenerationJob[]
  projects       Project[]
  audioJobs      AudioJob[]
  voiceJobs      VoiceJob[]
  voiceClones    VoiceClone[]
  characterVoices CharacterVoice[]
  speakerProfiles SpeakerProfile[]
}

/** Durable studio project — every generation creates/updates one. */
model Project {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  prompt          String?
  inputImageUrl   String?
  audioUrl        String?
  settings        Json?
  durationSeconds Int      @default(0)
  creditsUsed     Int      @default(0)
  provider        String?
  outputUrl       String?
  status          String   @default("queued")
  latestJobId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  generationJobs GenerationJob[]
  audioJobs      AudioJob[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
}

model GenerationJob {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId         String?
  project           Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status            GenerationJobStatus @default(QUEUED)
  prompt            String?
  inputImageUrl     String?
  audioUrl          String?
  generatedVideoUrl String?
  durationSeconds   Int                 @default(0)
  creditsCharged    Int                 @default(0)
  creditsDebited    Boolean             @default(false)
  provider          String?
  settings          Json?
  progressPercent   Int                 @default(0)
  stageLabel        String?
  queuePosition     Int?
  estimatedSecondsRemaining Int?
  retryCount        Int                 @default(0)
  chunkTotal        Int?
  chunksCompleted   Int?
  chunkManifest     Json?
  errorMessage      String?
  backendJobId      String?
  isPublic          Boolean             @default(false)
  shareTitle        String?
  publishedAt       DateTime?
  startedAt         DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  completedAt       DateTime?

  audioJobs         AudioJob[]

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([projectId])
  @@index([isPublic])
}

enum GenerationJobStatus {
  QUEUED
  PREPARING
  GENERATING
  GENERATING_CHUNKS
  RENDERING
  COMPILING_MEDIA
  UPLOADING
  COMPLETED
  FAILED
  CANCELLED
}

/** Phase 4 — AI Audio Production Engine jobs. */
model AudioJob {
  id                 String    @id @default(uuid())
  userId             String?
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId          String?
  project            Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  generationJobId    String?
  generationJob      GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)
  backendJobId       String?   @unique
  status             String    @default("queued")
  prompt             String?
  provider           String?
  engineVersion      String?
  durationSec        Float     @default(0)
  validationPassed   Boolean   @default(false)
  productionReady    Boolean   @default(false)
  exportReady        Boolean   @default(false)
  retryCount         Int       @default(0)
  queuePosition      Int?
  errorMessage       String?
  metadata           Json?
  timeline           Json?
  observability      Json?
  version            Int       @default(1)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  completedAt        DateTime?

  voiceAssets        VoiceAsset[]
  musicAssets        MusicAsset[]
  soundEffects       SoundEffectAsset[]
  timelineMeta       AudioTimelineMeta[]
  history            AudioGenerationHistory[]
  voiceJobs          VoiceJob[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([backendJobId])
}

model VoiceAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  text         String?
  character    String?
  language     String    @default("en")
  startSec     Float     @default(0)
  endSec       Float     @default(0)
  providerHint String?
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
  @@index([clipId])
}

model MusicAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  style        String?
  mood         String?
  startSec     Float     @default(0)
  endSec       Float     @default(0)
  loop         Boolean   @default(false)
  providerHint String?
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model SoundEffectAsset {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  clipId       String
  label        String?
  category     String?
  startSec     Float     @default(0)
  durationSec  Float     @default(0.5)
  assetUrl     String?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model AudioTimelineMeta {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  trackId      String
  kind         String
  gainDb       Float     @default(0)
  clips        Json?
  createdAt    DateTime  @default(now())

  @@index([audioJobId])
}

model AudioGenerationHistory {
  id           String    @id @default(uuid())
  audioJobId   String?
  audioJob     AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: Cascade)
  version      Int       @default(1)
  status       String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([audioJobId, createdAt(sort: Desc)])
}

/** Phase 4 Sprint 2 — Voice Generation Engine */
model VoiceJob {
  id                  String    @id @default(uuid())
  userId              String?
  user                User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  audioJobId          String?
  audioJob            AudioJob? @relation(fields: [audioJobId], references: [id], onDelete: SetNull)
  backendJobId        String?   @unique
  status              String    @default("queued")
  text                String
  language            String    @default("en")
  voiceId             String
  gender              String?
  provider            String?
  voiceModel          String?
  speed               Float     @default(1)
  pitch               Float     @default(0)
  volume              Float     @default(1)
  pauseMs             Int       @default(0)
  ssml                String?
  estimatedDurationSec Float    @default(0)
  qualityScore        Float?
  qualityGrade        String?
  assetUrl            String?
  productionReady     Boolean   @default(false)
  exportReady         Boolean   @default(false)
  retryCount          Int       @default(0)
  queuePosition       Int?
  errorMessage        String?
  version             Int       @default(1)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  completedAt         DateTime?

  profiles            VoiceProfile[]
  synthAssets         VoiceSynthAsset[]
  metaRecords         VoiceMeta[]
  historyEntries      VoiceHistoryEntry[]
  versions            VoiceVersion[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([language])
  @@index([backendJobId])
}

model VoiceProfile {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  voiceId      String
  name         String?
  language     String
  gender       String?
  style        String?
  providerModel String?
  sampleRate   Int       @default(24000)
  tags         Json?
  createdAt    DateTime  @default(now())

  @@index([voiceId])
  @@index([language])
  @@index([voiceJobId])
}

model VoiceSynthAsset {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  format       String    @default("wav")
  assetUrl     String?
  filename     String?
  bytes        Int?
  checksum     String?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId])
}

model VoiceMeta {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  key          String
  value        Json?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId, key])
}

model VoiceHistoryEntry {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  status       String?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId, createdAt(sort: Desc)])
}

model VoiceVersion {
  id           String    @id @default(uuid())
  voiceJobId   String?
  voiceJob     VoiceJob? @relation(fields: [voiceJobId], references: [id], onDelete: Cascade)
  version      Int
  ssml         String?
  assetUrl     String?
  qualityScore Float?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([voiceJobId, version])
}

// ---------------------------------------------------------------------------
// Phase 4 Sprint 3 — Voice Cloning & Character Voice
// ---------------------------------------------------------------------------

model VoiceClone {
  id                   String    @id @default(uuid())
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  backendCloneId       String?   @unique
  status               String    @default("queued")
  characterId          String?
  referenceUrl         String
  referenceChecksum    String?
  language             String    @default("en")
  accent               String    @default("neutral")
  speakingStyle        String    @default("natural")
  emotionProfile       String    @default("calm")
  gender               String?
  ageGroup             String?
  voiceLocked          Boolean   @default(false)
  voiceVersion         Int       @default(1)
  provider             String?
  qualityScore         Float?
  qualityGrade         String?
  speakerVerified      Boolean   @default(false)
  previewUrl           String?
  assetUrl             String?
  productionReady      Boolean   @default(false)
  retryCount           Int       @default(0)
  queuePosition        Int?
  errorMessage         String?
  trainingDurationMs   Float?
  processingTimeMs     Float?
  parentGenerationId   String?
  parentVideoJobId     String?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  characterVoices      CharacterVoice[]
  fingerprints         VoiceFingerprint[]
  cloneMeta            VoiceCloneMeta[]
  cloneVersions        VoiceCloneVersion[]
  trainingHistory      VoiceTrainingHistory[]
  speakerProfiles      SpeakerProfile[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([characterId])
  @@index([backendCloneId])
}

model CharacterVoice {
  id              String    @id @default(uuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  characterId     String
  voiceCloneId    String?
  voiceClone      VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: SetNull)
  defaultVoice    String
  language        String    @default("en")
  accent          String    @default("neutral")
  speakingStyle   String    @default("natural")
  emotionProfile  String    @default("calm")
  gender          String?
  ageGroup        String?
  voiceVersion    Int       @default(1)
  voiceLocked     Boolean   @default(false)
  speakerId       String?
  previewUrl      String?
  voiceMetadata   Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([characterId])
  @@index([userId])
  @@index([voiceCloneId])
  @@index([defaultVoice])
}

model SpeakerProfile {
  id              String    @id @default(uuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  voiceCloneId    String?
  voiceClone      VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  backendSpeakerId String?  @unique
  gender          String?
  ageGroup        String?
  language        String    @default("en")
  accent          String    @default("neutral")
  speakingStyle   String    @default("natural")
  emotionProfile  String    @default("calm")
  locked          Boolean   @default(false)
  version         Int       @default(1)
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fingerprints    VoiceFingerprint[]

  @@index([userId])
  @@index([voiceCloneId])
  @@index([backendSpeakerId])
}

model VoiceFingerprint {
  id              String    @id @default(uuid())
  voiceCloneId    String?
  voiceClone      VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  speakerProfileId String?
  speakerProfile  SpeakerProfile? @relation(fields: [speakerProfileId], references: [id], onDelete: SetNull)
  fingerprintId   String    @unique
  checksum        String
  embeddingRef    String?
  sampleRate      Int       @default(24000)
  durationSec     Float     @default(0)
  spectralHash    String?
  speakerScore    Float?
  createdAt       DateTime  @default(now())

  @@index([voiceCloneId])
  @@index([checksum])
  @@index([speakerProfileId])
}

model VoiceCloneMeta {
  id           String    @id @default(uuid())
  voiceCloneId String?
  voiceClone   VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  key          String
  value        Json?
  createdAt    DateTime  @default(now())

  @@index([voiceCloneId, key])
}

model VoiceCloneVersion {
  id           String    @id @default(uuid())
  voiceCloneId String?
  voiceClone   VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  version      Int
  assetUrl     String?
  previewUrl   String?
  qualityScore Float?
  snapshot     Json?
  createdAt    DateTime  @default(now())

  @@index([voiceCloneId, version])
}

model VoiceTrainingHistory {
  id                  String    @id @default(uuid())
  voiceCloneId        String?
  voiceClone          VoiceClone? @relation(fields: [voiceCloneId], references: [id], onDelete: Cascade)
  version             Int
  trainingDurationMs  Float?
  provider            String?
  qualityScore        Float?
  status              String?
  snapshot            Json?
  createdAt           DateTime  @default(now())

  @@index([voiceCloneId, createdAt(sort: Desc)])
}
