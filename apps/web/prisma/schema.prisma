  createdAt        DateTime @default(now())

  @@index([eventId])
  @@index([eventType, createdAt(sort: Desc)])
  @@index([organizationId])
  @@map("PaddleWebhookLogs")
}

model BillingEvent {
  id               String   @id @default(uuid())
