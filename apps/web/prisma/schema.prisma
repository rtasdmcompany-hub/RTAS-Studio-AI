  @@unique([organizationId, slug])
  @@index([organizationId, assetType, createdAt(sort: Desc)])
  @@index([workspaceId, status])
  @@index([ownerId])
  @@index([category])
  @@index([status])
  @@index([isFavorite])
  @@index([deletedAt])
}

model LibraryAssetVersion {
