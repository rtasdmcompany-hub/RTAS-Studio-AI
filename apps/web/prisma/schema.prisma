  isValid       Boolean  @default(true)
  validatedAt   DateTime?
  validationMsg String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([environment])
}

model FeatureFlag {
  id             String   @id @default(uuid())
