# =============================================================================
# RTAS Studio AI — PRODUCTION environment template
# =============================================================================
# Copy values into Vercel → Project → Settings → Environment Variables
# (Production + Preview as appropriate). NEVER commit real secrets.
#
# Placeholders use REPLACE_* — swap when credentials/domains are ready.
# After filling: npm run verify:production -w @rtas/web
#                npm run probe:services -w @rtas/web
#                npm run env:vercel -w @rtas/web   # optional sync from .env.local
# =============================================================================

# --- Canonical public origins (apex — not www, not localhost) ----------------
NEXT_PUBLIC_APP_URL=https://rtasstudio.com
NEXTAUTH_URL=https://rtasstudio.com

# --- Auth --------------------------------------------------------------------
# openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_NEXTAUTH_SECRET
GOOGLE_CLIENT_ID=REPLACE_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_GOOGLE_OAUTH_CLIENT_SECRET
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
GOOGLE_OAUTH_REDIRECT_URI=https://rtasstudio.com/api/auth/callback/google
GOOGLE_OAUTH_JS_ORIGIN=https://rtasstudio.com
# Optional preview / www aliases
GOOGLE_OAUTH_REDIRECT_URI_ALT=https://www.rtasstudio.com/api/auth/callback/google
GOOGLE_OAUTH_JS_ORIGIN_ALT=https://www.rtasstudio.com

# --- Database (Supabase / Neon pooled Postgres — Prisma) ---------------------
# Prefer session/transaction pooler (IPv4) for Vercel serverless
DATABASE_URL=postgresql://REPLACE_DB_USER:REPLACE_DB_PASSWORD@REPLACE_DB_HOST:6543/postgres?pgbouncer=true&sslmode=require
# Optional direct (migrations / Prisma migrate)
DATABASE_URL_DIRECT=postgresql://REPLACE_DB_USER:REPLACE_DB_PASSWORD@db.REPLACE_SUPABASE_REF.supabase.co:5432/postgres?sslmode=require

# --- Supabase (optional REST/storage; auth remains NextAuth) -----------------
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_SUPABASE_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_SUPABASE_ANON_OR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_SUPABASE_SERVICE_ROLE_OR_SECRET_KEY

# --- Persistent store (REQUIRED on Vercel for auth/session durability) -------
# Link Vercel KV (auto-injects) OR set Upstash manually:
KV_REST_API_URL=https://REPLACE_KV_HOST
KV_REST_API_TOKEN=REPLACE_KV_TOKEN
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- GPU worker (public HTTPS FastAPI — NOT localhost) -----------------------
FASTAPI_URL=https://api.REPLACE_APP_DOMAIN
NEXT_PUBLIC_FASTAPI_URL=https://api.REPLACE_APP_DOMAIN
RTAS_GENERATION_WEBHOOK_SECRET=REPLACE_GENERATION_WEBHOOK_SECRET

# --- AI providers (at least one required for live generation) ----------------
FAL_KEY=REPLACE_FAL_KEY
# REPLICATE_API_TOKEN=
# RUNWAY_API_KEY=
# KLING_API_KEY=

# --- Email (Resend preferred; verified domain required) ----------------------
RESEND_API_KEY=REPLACE_RESEND_API_KEY
EMAIL_FROM="RTAS STUDIO AI <auth@rtasstudio.com>"
# SMTP fallback (optional if Resend is configured)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# --- Payments (Merchant of Record) -------------------------------------------
NEXT_PUBLIC_PAYMENT_PROVIDER=paddle

# Paddle production
PADDLE_WEBHOOK_SECRET=REPLACE_PADDLE_WEBHOOK_SECRET
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=REPLACE_PADDLE_CLIENT_TOKEN
NEXT_PUBLIC_PADDLE_CHECKOUT_URL=https://REPLACE_PADDLE_CHECKOUT_HOST/...
NEXT_PUBLIC_PADDLE_TESTER_CHECKOUT_URL=https://REPLACE_PADDLE_CHECKOUT_HOST/...
NEXT_PUBLIC_PADDLE_STANDARD_CHECKOUT_URL=https://REPLACE_PADDLE_CHECKOUT_HOST/...
NEXT_PUBLIC_PADDLE_PREMIUM_CHECKOUT_URL=https://REPLACE_PADDLE_CHECKOUT_HOST/...
# PADDLE_TESTER_PRICE_ID=
# PADDLE_STANDARD_PRICE_ID=
# PADDLE_PREMIUM_PRICE_ID=

# Lemon Squeezy alternative (set NEXT_PUBLIC_PAYMENT_PROVIDER=lemon_squeezy)
# LEMONSQUEEZY_WEBHOOK_SECRET=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_VARIANT_ID=
# NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=

# --- Fal funding / admin -----------------------------------------------------
FAL_ADMIN_API_KEY=REPLACE_FAL_ADMIN_OR_SAME_AS_FAL_KEY
FAL_USD_PER_CREDIT=0.0195
FAL_POOL_BUFFER_PERCENT=20
RTAS_ADMIN_SECRET=REPLACE_ADMIN_SECRET

# Local-only escapes (never set in Vercel Production)
# ALLOW_UNSIGNED_WEBHOOKS=1
# RTAS_ALLOW_OPEN_ADMIN=1

# Owner diagnostic UI (comma-separated emails)
# NEXT_PUBLIC_OWNER_EMAILS=ops@REPLACE_EMAIL_DOMAIN

# --- Observability (optional — enable when accounts ready) -------------------
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# NEXT_PUBLIC_ANALYTICS_ID=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- CDN / asset hosts (optional future) -------------------------------------
# NEXT_PUBLIC_CDN_URL=https://cdn.REPLACE_APP_DOMAIN
# NEXT_PUBLIC_ASSETS_URL=https://assets.REPLACE_APP_DOMAIN

# --- Ops tooling (local CLI only — never expose to browser) ------------------
# VERCEL_TOKEN=
# GITHUB_TOKEN=
