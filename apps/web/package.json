{
  "name": "@rtas/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup:env": "node ./scripts/setup-env.mjs",
    "setup:env:ps1": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-env.ps1",
    "verify:google-oauth": "node ./scripts/verify-google-oauth.mjs",
    "verify:env": "node ./scripts/verify-env-local.mjs",
    "test:smtp": "node ./scripts/test-smtp.mjs",
    "verify:replicate": "node ./scripts/verify-replicate-env.mjs",
    "fetch:preview": "node ./scripts/fetch-preview-sample.mjs",
    "predev": "npm run setup:env && npm run fetch:preview",
    "clean:next": "node ./scripts/clean-next-cache.mjs",
    "dev": "next dev",
    "dev:fast": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@rtas/shared": "*",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^2.4.3",
    "next": "^14.2.0",
    "next-auth": "^4.24.11",
    "nodemailer": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.4.0"
  }
}
