# Copy to .env.local — or run: npm run setup:env (auto-generates secrets)

# Authentication (NextAuth) — required for /studio access
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# Google Cloud Console → OAuth Web client (register these exactly):
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
GOOGLE_OAUTH_JS_ORIGIN=http://localhost:3000
GOOGLE_OAUTH_REDIRECT_URI_ALT=http://127.0.0.1:3000/api/auth/callback/google
GOOGLE_OAUTH_JS_ORIGIN_ALT=http://127.0.0.1:3000

# Merchant of Record — choose one: paddle | lemon_squeezy
NEXT_PUBLIC_PAYMENT_PROVIDER=paddle

# Paddle (https://www.paddle.com)
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_CHECKOUT_URL=
NEXT_PUBLIC_PADDLE_TESTER_CHECKOUT_URL=
PADDLE_TESTER_PRICE_ID=

# Lemon Squeezy (https://www.lemonsqueezy.com)
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_TESTER_VARIANT_ID=
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=
NEXT_PUBLIC_LEMONSQUEEZY_TESTER_CHECKOUT_URL=

# Fal funding monitor (after each customer payment — balance check + ledger)
FAL_ADMIN_API_KEY=
FAL_USD_PER_CREDIT=0.0195
FAL_POOL_BUFFER_PERCENT=20
RTAS_ADMIN_SECRET=

# AI providers (at least one for production)
RUNWAY_API_KEY=
KLING_API_KEY=
REPLICATE_API_TOKEN=
FAL_KEY=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email confirmation (choose Resend OR SMTP)
# Resend: https://resend.com — verify your sending domain in production
RESEND_API_KEY=
EMAIL_FROM="RTAS STUDIO AI <noreply@yourdomain.com>"

# SMTP fallback (e.g. Gmail app password)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# FastAPI backend (optional — enables POST http://localhost:8000/api/generate)
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# Persistent storage (required on Vercel — add Vercel KV from Storage tab)
# Vercel auto-injects KV_REST_API_URL and KV_REST_API_TOKEN when KV is linked.
# Or use Upstash Redis directly:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Pakistan payments (configure when merchant accounts ready)
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
EASYPAISA_STORE_ID=
