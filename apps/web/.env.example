# =============================================================================
# RTAS Studio AI — local development environment template
# =============================================================================
# Copy to .env.local:
#   cp .env.example .env.local
# Or: npm run setup:env -w @rtas/web
#
# Production template: .env.production.example
# Full variable reference: docs/ENVIRONMENT.md
# NEVER commit .env.local or real secrets.
# =============================================================================

# --- Database (Prisma → Postgres) --------------------------------------------
# Local: postgresql://postgres:password@localhost:5432/rtas_studio
# Supabase/Neon: use pooled connection string (IPv4 session pooler preferred)
DATABASE_URL=
# Optional direct URI for migrations
# DATABASE_URL_DIRECT=

# --- NextAuth ----------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
GOOGLE_OAUTH_JS_ORIGIN=http://localhost:3000
GOOGLE_OAUTH_REDIRECT_URI_ALT=http://127.0.0.1:3000/api/auth/callback/google
GOOGLE_OAUTH_JS_ORIGIN_ALT=http://127.0.0.1:3000

# --- App URL -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (optional — auth is NextAuth, not Supabase Auth) ---------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Merchant of Record: lemon_squeezy (recommended) | paddle (legacy) -------
# Sprint 2/3: preferred strategic provider is lemon_squeezy. Active runtime
# still follows this ENV value — set lemon_squeezy when LS store is configured.
NEXT_PUBLIC_PAYMENT_PROVIDER=paddle

# Paddle (legacy adapter — https://www.paddle.com)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_CHECKOUT_URL=
NEXT_PUBLIC_PADDLE_TESTER_CHECKOUT_URL=
NEXT_PUBLIC_PADDLE_STANDARD_CHECKOUT_URL=
NEXT_PUBLIC_PADDLE_PREMIUM_CHECKOUT_URL=
PADDLE_TESTER_PRICE_ID=
PADDLE_STANDARD_PRICE_ID=
PADDLE_PREMIUM_PRICE_ID=

# Lemon Squeezy (recommended — https://www.lemonsqueezy.com)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_TESTER_VARIANT_ID=
LEMONSQUEEZY_STANDARD_VARIANT_ID=
LEMONSQUEEZY_PREMIUM_VARIANT_ID=
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=
NEXT_PUBLIC_LEMONSQUEEZY_TESTER_CHECKOUT_URL=
NEXT_PUBLIC_LEMONSQUEEZY_STANDARD_CHECKOUT_URL=
NEXT_PUBLIC_LEMONSQUEEZY_PREMIUM_CHECKOUT_URL=

# --- Fal funding monitor (post-payment balance / ledger) ---------------------
FAL_ADMIN_API_KEY=
FAL_USD_PER_CREDIT=0.0195
FAL_POOL_BUFFER_PERCENT=20
RTAS_ADMIN_SECRET=

# --- AI providers (at least one for live generation) -------------------------
FAL_KEY=
REPLICATE_API_TOKEN=
RUNWAY_API_KEY=
KLING_API_KEY=

# --- Email (Resend OR SMTP) --------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="RTAS STUDIO AI <auth@rtasstudio.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- FastAPI GPU worker ------------------------------------------------------
FASTAPI_URL=http://localhost:8000
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
RTAS_GENERATION_WEBHOOK_SECRET=
# AI_BACKEND_SECRET=

# --- Persistent storage (required on Vercel; optional locally) ---------------
# Vercel KV auto-injects KV_REST_API_URL + KV_REST_API_TOKEN when linked.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Observability placeholders (optional) -----------------------------------
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# Product analytics — do NOT invent traffic. Leave unset until vendor accounts exist.
# NEXT_PUBLIC_ANALYTICS_ID=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_GTM_ID=
# Optional marketing pixels (consent-gated; not auto-injected)
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
# NEXT_PUBLIC_CLARITY_ID=
# Google Search Console uses meta/DNS verification — no runtime ID required in app.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_GTM_ID=
# Search Console / Bing meta verification tokens (public; not secrets)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_SITE_VERIFICATION=

# --- Future CDN / domains (placeholders) -------------------------------------
# NEXT_PUBLIC_CDN_URL=
# NEXT_PUBLIC_ASSETS_URL=

# --- Ops CLI only (never ship to browser) ------------------------------------
# VERCEL_TOKEN=
# GITHUB_TOKEN=

# ALLOW_UNSIGNED_WEBHOOKS=
# RTAS_ALLOW_OPEN_ADMIN=
# NEXT_PUBLIC_OWNER_EMAILS=

# --- Affiliate / partner program (Phase 13 Sprint 5) -------------------------
# Cookie attribution window in days (default 30). Public pages read this.
AFFILIATE_COOKIE_DAYS=30
# HARD GATE: leave false until attribution + payout rails + tax ops are ready.
# Never market live earnings while this is false / unset.
AFFILIATE_PAYOUTS_LIVE=false
AFFILIATE_MIN_PAYOUT_USD=50
AFFILIATE_PAYOUT_NET_DAYS=30

# --- Pakistan payments (future — not wired in app code yet) ------------------
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
EASYPAISA_STORE_ID=
