{
  "name": "@rtas/rtas-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "RTAS Studio AI — Capacitor native shell for iOS and Android (remote web hook)",
  "scripts": {
    "start": "npx cap serve",
    "sync": "npx cap sync",
    "copy": "npx cap copy",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "add:android": "npx cap add android",
    "add:ios": "npx cap add ios",
    "assets:prepare": "node scripts/prepare-mobile-assets.mjs",
    "assets:generate": "node scripts/prepare-mobile-assets.mjs && npx @capacitor/assets generate --ios --android --iconBackgroundColor \"#0a0a0f\" --iconBackgroundColorDark \"#0a0a0f\" --splashBackgroundColor \"#0a0a0f\" --splashBackgroundColorDark \"#0a0a0f\" --logoSplashScale 0.35 --iosProject ios/App --androidProject android",
    "assets:generate:android": "node scripts/prepare-mobile-assets.mjs && npx @capacitor/assets generate --android --iconBackgroundColor \"#0a0a0f\" --iconBackgroundColorDark \"#0a0a0f\" --splashBackgroundColor \"#0a0a0f\" --splashBackgroundColorDark \"#0a0a0f\" --logoSplashScale 0.35 --androidProject android",
    "assets:generate:ios": "node scripts/prepare-mobile-assets.mjs && npx @capacitor/assets generate --ios --iconBackgroundColor \"#0a0a0f\" --iconBackgroundColorDark \"#0a0a0f\" --splashBackgroundColor \"#0a0a0f\" --splashBackgroundColorDark \"#0a0a0f\" --logoSplashScale 0.35 --iosProject ios/App",
    "assets:check": "node scripts/check-mobile-ready.mjs",
    "postassets:generate": "npx cap sync"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "typescript": "~5.3.3"
  },
  "engines": {
    "node": "20.x"
  }
}
